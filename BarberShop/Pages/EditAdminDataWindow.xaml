<Window x:Class="BarberShop.Pages.EditAdminDataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование данных администратора"
        Height="500" Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#FF090909"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- Стиль для полей ввода -->
        <Style x:Key="EditTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="BorderBrush" Value="#FF333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10 5"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="15" Background="#FF141414" BorderBrush="#CE7802" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Grid Grid.Row="0" Margin="0 0 0 20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="РЕДАКТИРОВАНИЕ ДАННЫХ" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1" 
                        x:Name="CloseButton"
                        Content="✕"
                        Background="Transparent"
                        BorderBrush="#CE7802"
                        BorderThickness="1"
                        Foreground="#CE7802"
                        Width="30"
                        Height="30"
                        FontSize="16"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="CloseButton_Click"/>
            </Grid>

            <!-- Форма редактирования -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Фамилия -->
                    <TextBlock Text="Фамилия *" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <TextBox x:Name="LastNameTextBox" 
                             Style="{StaticResource EditTextBoxStyle}"/>

                    <!-- Имя -->
                    <TextBlock Text="Имя *" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <TextBox x:Name="FirstNameTextBox" 
                             Style="{StaticResource EditTextBoxStyle}"/>

                    <!-- Телефон -->
                    <TextBlock Text="Телефон *" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <TextBox x:Name="PhoneTextBox" 
                             Style="{StaticResource EditTextBoxStyle}"/>

                    <!-- Email (логин) -->
                    <TextBlock Text="Email (логин) *" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <TextBox x:Name="EmailTextBox" 
                             Style="{StaticResource EditTextBoxStyle}"/>

                    <TextBlock Text="Email будет использоваться как логин для входа"
                               Foreground="#CE7802"
                               FontSize="12"
                               Margin="5 0 5 15"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Кнопки -->
            <Grid Grid.Row="2" Margin="0 20 0 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" 
                        x:Name="CancelButton"
                        Content="Отмена"
                        Height="45"
                        Background="Transparent"
                        BorderBrush="#FF333333"
                        BorderThickness="2"
                        Foreground="#CCCCCC"
                        FontSize="16"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Margin="0 0 5 0"
                        Click="CancelButton_Click"/>

                <Button Grid.Column="1" 
                        x:Name="SaveButton"
                        Content="Сохранить"
                        Height="45"
                        Background="#CE7802"
                        BorderThickness="0"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Margin="5 0 0 0"
                        Click="SaveButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>