<Page x:Class="BarberShop.Pages.ClientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="1080" d:DesignWidth="1920"
      Title="ClientPage"
      Background="#FF090909"
      Loaded="Page_Loaded">

    <Page.Resources>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0 20 0 20"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0 0 20 20"/>
        </Style>

        <Style x:Key="ProductCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0 0 20 20"/>
            <Setter Property="Width" Value="250"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF090909" Offset="0"/>
                    <GradientStop Color="#FF1A1A1A" Offset="0.5"/>
                    <GradientStop Color="#FF090909" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <StackPanel Margin="50">

                <!-- Верхняя панель с логотипом и кнопкой выхода -->
                <Grid Margin="0 0 0 30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Логотип слева -->
                    <Image Grid.Column="0" 
                           Source="/Iamges/logo.png" 
                           Height="60" 
                           Width="60"
                           Margin="0 0 20 0"/>

                    <!-- Приветствие по центру -->
                    <TextBlock Grid.Column="1" 
                               x:Name="WelcomeTextBlock"
                               Text="Добро пожаловать, Имя!"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"/>

                    <!-- Кнопка выхода справа -->
                    <Button Grid.Column="2" 
                            x:Name="LogoutButton"
                            Content="🚪 Выйти"
                            Background="Transparent"
                            BorderBrush="#CE7802"
                            BorderThickness="2"
                            Foreground="#CE7802"
                            FontSize="16"
                            FontWeight="Bold"
                            Padding="20 10"
                            Cursor="Hand"
                            Click="LogoutButton_Click"/>
                </Grid>

                <!-- Секция с данными клиента -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Аватарка -->
                        <Border Grid.Row="0" Grid.Column="0"
                                Background="#CE7802"
                                Width="80"
                                Height="80"
                                CornerRadius="40"
                                Margin="0 0 20 0"
                                VerticalAlignment="Top">
                            <TextBlock Text="👤"
                                       FontSize="40"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Информация о клиенте -->
                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock x:Name="ClientNameText"
                                       Text="Иванов Иван"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="ClientPhoneText"
                                       Text="+7 (999) 123-45-67"
                                       FontSize="16"
                                       Foreground="#CCCCCC"
                                       Margin="0 5 0 0"/>
                            <TextBlock x:Name="ClientEmailText"
                                       Text="ivan@example.com"
                                       FontSize="16"
                                       Foreground="#CCCCCC"/>
                            <TextBlock x:Name="ClientBirthDateText"
                                       Text="Дата рождения: 01.01.1990"
                                       FontSize="16"
                                       Foreground="#CE7802"
                                       Margin="0 5 0 0"/>
                        </StackPanel>

                        <!-- Кнопка смены пароля -->
                        <Button Grid.Row="0" Grid.Column="2"
                                x:Name="ChangePasswordButton"
                                Content="🔑 Сменить пароль"
                                Background="Transparent"
                                BorderBrush="#CE7802"
                                BorderThickness="2"
                                Foreground="#CE7802"
                                FontSize="14"
                                FontWeight="Bold"
                                Padding="15 8"
                                Cursor="Hand"
                                VerticalAlignment="Top"
                                Click="ChangePasswordButton_Click"/>
                    </Grid>
                </Border>

                <!-- Предстоящие записи -->
                <TextBlock Text="Мои записи" Style="{StaticResource SectionTitleStyle}"/>

                <ItemsControl x:Name="UpcomingAppointmentsList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}" Margin="0 0 0 15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Иконка -->
                                    <Border Grid.Row="0" Grid.Column="0"
                                            Background="#CE7802"
                                            Width="50"
                                            Height="50"
                                            CornerRadius="25"
                                            Margin="0 0 15 0"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="💈"
                                                   FontSize="24"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Информация о записи -->
                                    <StackPanel Grid.Row="0" Grid.Column="1">
                                        <TextBlock Text="{Binding ServiceName}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Margin="0 5 0 0">
                                            <Run Text="Мастер:" Foreground="#CCCCCC"/>
                                            <Run Text="{Binding EmployeeName}" Foreground="White"/>
                                        </TextBlock>
                                        <WrapPanel Margin="0 5 0 0">
                                            <TextBlock Text="📅" Foreground="#CE7802" Margin="0 0 5 0"/>
                                            <TextBlock Text="{Binding AppointmentDate}" 
                                                       Foreground="White"
                                                       Margin="0 0 15 0"/>
                                            <TextBlock Text="⏰" Foreground="#CE7802" Margin="0 0 5 0"/>
                                            <TextBlock Text="{Binding StartTime}" Foreground="White"/>
                                        </WrapPanel>
                                    </StackPanel>

                                    <!-- Статус -->
                                    <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                            Background="#4CAF50"
                                            CornerRadius="5"
                                            Padding="10 5"
                                            Margin="0 10 0 0"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Status}"
                                                   Foreground="White"
                                                   FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Сообщение, если нет записей -->
                <TextBlock x:Name="NoUpcomingAppointmentsText"
                           Text="У вас пока нет предстоящих записей"
                           Foreground="#666666"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           Margin="0 20"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>

                <!-- Прошедшие записи -->
                <TextBlock Text="История посещений" Style="{StaticResource SectionTitleStyle}"/>

                <ItemsControl x:Name="PastAppointmentsList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}" Margin="0 0 0 15" Opacity="0.8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Иконка -->
                                    <Border Grid.Row="0" Grid.Column="0"
                                            Background="#666666"
                                            Width="50"
                                            Height="50"
                                            CornerRadius="25"
                                            Margin="0 0 15 0"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="✓"
                                                   FontSize="24"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="White"/>
                                    </Border>

                                    <!-- Информация о записи -->
                                    <StackPanel Grid.Row="0" Grid.Column="1">
                                        <TextBlock Text="{Binding ServiceName}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Margin="0 5 0 0">
                                            <Run Text="Мастер:" Foreground="#CCCCCC"/>
                                            <Run Text="{Binding EmployeeName}" Foreground="White"/>
                                        </TextBlock>
                                        <WrapPanel Margin="0 5 0 0">
                                            <TextBlock Text="📅" Foreground="#CE7802" Margin="0 0 5 0"/>
                                            <TextBlock Text="{Binding AppointmentDate}" 
                                                       Foreground="White"/>
                                        </WrapPanel>
                                    </StackPanel>

                                    <!-- Статус -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                               Text="{Binding Status}"
                                               Foreground="#666666"
                                               Margin="0 10 0 0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Товары для покупки -->
                <TextBlock Text="Товары для ухода" Style="{StaticResource SectionTitleStyle}"/>

                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" x:Name="ProductsPanel" Margin="0 0 20 0"/>
                </ScrollViewer>

                <!-- Сообщение, если нет товаров -->
                <TextBlock x:Name="NoProductsText"
                           Text="Товары временно отсутствуют"
                           Foreground="#666666"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           Margin="0 20"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>

                <!-- Нижний колонтитул -->
                <Border Background="#FF1E1E1E" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="0 30 0 0">
                    <TextBlock Text="© 2026 BARBERSHOP «ПОДДУБНЫЙ». Все права защищены." 
                               Foreground="#666666" 
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>