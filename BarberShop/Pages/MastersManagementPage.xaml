<Page x:Class="BarberShop.Pages.MastersManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="1080" d:DesignWidth="1920"
      Title="MastersManagementPage"
      Background="#FF090909"
      Loaded="Page_Loaded">

    <Page.Resources>
        <!-- Стиль для кнопок действий -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#CE7802"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="15 0"/>
        </Style>

        <!-- Стиль для карточки мастера -->
        <Style x:Key="MasterCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
        </Style>

        <!-- Стиль для маленьких иконок-кнопок -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#CE7802"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#CE7802"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2"/>
        </Style>

        <!-- Стиль для карточки записи внутри мастера -->
        <Style x:Key="AppointmentMiniCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0 0 10 5"/>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Фоновый градиент -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF090909" Offset="0"/>
                <GradientStop Color="#FF1A1A1A" Offset="0.5"/>
                <GradientStop Color="#FF090909" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">

                <!-- Верхняя панель с логотипом, заголовком и кнопкой назад -->
                <Grid Margin="0 0 0 30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Логотип слева -->
                    <Image Grid.Column="0" 
                           Source="/Iamges/logo.png" 
                           Height="60" 
                           Width="60"
                           Margin="0 0 20 0"/>

                    <!-- Заголовок по центру -->
                    <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="УПРАВЛЕНИЕ МАСТЕРАМИ" 
                                  FontSize="28"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"/>
                        <TextBlock x:Name="AdminInfoText"
                                  Text="Администратор: Загрузка..."
                                  Foreground="#CE7802"
                                  FontSize="14"
                                  HorizontalAlignment="Center"
                                  Margin="0 5 0 0"/>
                    </StackPanel>

                    <!-- Кнопка назад (выход на страницу администратора) -->
                    <Button Grid.Column="2" 
                            x:Name="BackButton"
                            Content="← Назад"
                            Background="Transparent"
                            BorderBrush="#CE7802"
                            BorderThickness="2"
                            Foreground="#CE7802"
                            FontSize="16"
                            FontWeight="Bold"
                            Padding="20 10"
                            Cursor="Hand"
                            Click="BackButton_Click"/>
                </Grid>

                <!-- Панель поиска и добавления -->
                <Border Background="#FF141414" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="0 0 0 30">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Поиск -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border Background="#FF1E1E1E" 
                                    CornerRadius="5" 
                                    Width="300"
                                    Height="40">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" 
                                               Text="🔍" 
                                               FontSize="16" 
                                               Foreground="#666666"
                                               Margin="10 0 5 0"
                                               VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" 
                                             x:Name="SearchTextBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="White"
                                             FontSize="14"
                                             VerticalAlignment="Center"
                                             TextChanged="SearchTextBox_TextChanged"
                                             ToolTip="Введите имя или фамилию мастера"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Кнопка добавления мастера -->
                        <Button Grid.Column="1" 
                                x:Name="AddMasterButton"
                                Style="{StaticResource ActionButtonStyle}"
                                Width="180"
                                Click="AddMasterButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="➕" FontSize="16" Margin="0 0 10 0"/>
                                <TextBlock Text="Добавить мастера"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Список мастеров -->
                <ItemsControl x:Name="MastersList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource MasterCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Основная информация о мастере -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0 0 0 15">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Аватарка мастера -->
                                            <Border Grid.Column="0"
                                                    Background="#CE7802"
                                                    Width="60"
                                                    Height="60"
                                                    CornerRadius="30"
                                                    Margin="0 0 15 0">
                                                <TextBlock Text="💇" 
                                                           FontSize="30" 
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Имя и должность -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FullName}"
                                                           FontSize="22"
                                                           FontWeight="Bold"
                                                           Foreground="White"/>
                                                <TextBlock Text="{Binding PositionName}"
                                                    Foreground="#CE7802"
                                                    FontSize="14"
                                                    Margin="0 2 0 0"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Контактная информация -->
                                        <WrapPanel Margin="65 5 0 0">
                                            <Border Background="#FF2A2A2A"
                                                    CornerRadius="5"
                                                    Padding="8 3"
                                                    Margin="0 0 10 5">
                                                <TextBlock>
                                                    <Run Text="📞 " Foreground="#CE7802"/>
                                                    <Run Text="{Binding Phone}" Foreground="White"/>
                                                </TextBlock>
                                            </Border>

                                            <Border Background="#FF2A2A2A"
                                                    CornerRadius="5"
                                                    Padding="8 3"
                                                    Margin="0 0 10 5">
                                                <TextBlock>
                                                    <Run Text="👤 " Foreground="#CE7802"/>
                                                    <Run Text="Логин: " Foreground="#999999"/>
                                                    <Run Text="{Binding Login}" Foreground="White"/>
                                                </TextBlock>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>

                                    <!-- Кнопка смены пароля -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" 
                                                Orientation="Horizontal"
                                                VerticalAlignment="Top">
                                        <Button x:Name="ChangePasswordButton"
                                                Style="{StaticResource IconButtonStyle}"
                                                ToolTip="Сменить пароль"
                                                Tag="{Binding UserId}"
                                                Click="ChangePasswordButton_Click">
                                            <TextBlock Text="🔑" FontSize="18"/>
                                        </Button>
                                    </StackPanel>

                                    <!-- Действующие записи мастера -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                Margin="0 15 0 0">
                                        <TextBlock Text="ДЕЙСТВУЮЩИЕ ЗАПИСИ" 
                                                   Foreground="#999999" 
                                                   FontSize="12" 
                                                   Margin="0 0 0 10"/>

                                        <ItemsControl x:Name="AppointmentsList" 
                                                      ItemsSource="{Binding ActiveAppointments}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource AppointmentMiniCardStyle}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Клиент -->
                                                            <TextBlock Grid.Column="0" 
                                                                       Text="{Binding ClientName}"
                                                                       Foreground="White"
                                                                       FontWeight="Bold"
                                                                       Width="180"
                                                                       TextTrimming="CharacterEllipsis"/>

                                                            <!-- Услуга -->
                                                            <TextBlock Grid.Column="1" 
                                                                       Text="{Binding ServiceName}"
                                                                       Foreground="#CE7802"
                                                                       Margin="10 0"/>

                                                            <!-- Дата и время -->
                                                            <StackPanel Grid.Column="2" 
                                                                        Orientation="Horizontal">
                                                                <TextBlock Text="📅" 
                                                                           Foreground="#CE7802" 
                                                                           Margin="0 0 3 0"/>
                                                                <TextBlock Text="{Binding AppointmentDate}" 
                                                                           Foreground="White"
                                                                           Margin="0 0 10 0"/>
                                                                <TextBlock Text="⏰" 
                                                                           Foreground="#CE7802" 
                                                                           Margin="0 0 3 0"/>
                                                                <TextBlock Text="{Binding StartTime}" 
                                                                           Foreground="White"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Сообщение, если нет активных записей -->
                                        <TextBlock x:Name="NoAppointmentsText"
                                                   Text="Нет действующих записей"
                                                   Foreground="#666666"
                                                   FontSize="12"
                                                   Margin="0 5"
                                                   Visibility="{Binding HasNoAppointments}"/>
                                    </StackPanel>

                                    <!-- Статус активности мастера -->
                                    <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                            Background="{Binding StatusColor}"
                                            CornerRadius="5"
                                            Padding="10 5"
                                            Margin="0 15 0 0"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="White"
                                                   FontSize="12"
                                                   FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Сообщение, если мастера не найдены -->
                <TextBlock x:Name="NoMastersText"
                           Text="Мастера не найдены"
                           Foreground="#666666"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           Margin="0 50"
                           Visibility="Collapsed"/>

                <!-- Нижний колонтитул -->
                <Border Background="#FF1E1E1E" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="0 30 0 0">
                    <TextBlock Text="© 2026 BARBERSHOP «ПОДДУБНЫЙ». Все права защищены." 
                               Foreground="#666666" 
                               HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>