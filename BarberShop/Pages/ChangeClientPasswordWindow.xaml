<Window x:Class="BarberShop.Pages.ChangeClientPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменение пароля клиента"
        Height="442" Width="496"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#FF090909"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="15" Background="#FF141414" BorderBrush="#CE7802" BorderThickness="1" Margin="10,0,0,0">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition Height="0"/>
                <RowDefinition Height="78"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           x:Name="TitleText"
                           Text="ИЗМЕНЕНИЕ ПАРОЛЯ" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1" 
                        x:Name="CloseButton"
                        Content="✕"
                        Background="Transparent"
                        BorderBrush="#CE7802"
                        BorderThickness="1"
                        Foreground="#CE7802"
                        Width="30"
                        Height="30"
                        FontSize="16"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="CloseButton_Click"/>
            </Grid>

            <!-- Форма -->
            <StackPanel Grid.Row="1" Height="269" VerticalAlignment="Top">

                <!-- Информация о клиенте -->
                <Border Background="#FF1E1E1E"
                        CornerRadius="5"
                        Padding="15"
                        Margin="0 0 0 20">
                    <TextBlock x:Name="ClientInfoText"
                               Foreground="#CE7802"
                               FontSize="14"
                               FontWeight="Bold"
                               TextAlignment="Center"/>
                </Border>

                <!-- Новый пароль -->
                <TextBlock Text="Новый пароль *" 
                           Foreground="#CCCCCC" 
                           Margin="5 0 5 5" 
                           FontSize="14"/>
                <PasswordBox x:Name="NewPasswordBox" 
                             Height="40" 
                             Background="#FF1E1E1E" 
                             BorderBrush="#FF333333" 
                             BorderThickness="1" 
                             Foreground="White" 
                             FontSize="14" 
                             Padding="10 5" 
                             Margin="0 0 0 15"/>

                <!-- Подтверждение пароля -->
                <TextBlock Text="Подтверждение пароля *" 
                           Foreground="#CCCCCC" 
                           Margin="5 0 5 5" 
                           FontSize="14"/>
                <PasswordBox x:Name="ConfirmPasswordBox" 
                             Height="40" 
                             Background="#FF1E1E1E" 
                             BorderBrush="#FF333333" 
                             BorderThickness="1" 
                             Foreground="White" 
                             FontSize="14" 
                             Padding="10 5" 
                             Margin="0 0 0 15"/>

                <TextBlock Text="Пароль должен содержать не менее 6 символов"
                           Foreground="#666666"
                           FontSize="12"
                           Margin="5 0 0 0"/>
            </StackPanel>

            <!-- Кнопки -->
            <Grid Grid.Row="3" Margin="0,2,0,-2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" 
                        x:Name="CancelButton"
                        Content="Отмена"
                        Height="40"
                        Background="Transparent"
                        BorderBrush="#FF333333"
                        BorderThickness="2"
                        Foreground="#CCCCCC"
                        FontSize="14"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Margin="0 0 5 0"
                        Click="CancelButton_Click"/>

                <Button Grid.Column="1" 
                        x:Name="SaveButton"
                        Content="Сохранить"
                        Height="40"
                        Background="#CE7802"
                        BorderThickness="0"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Margin="5 0 0 0"
                        Click="SaveButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>