<Window x:Class="BarberShop.Pages.EditAppointmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование записи"
        Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#FF090909"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="15" Background="#FF141414" BorderBrush="#CE7802" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Grid Grid.Row="0" Margin="0 0 0 20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="РЕДАКТИРОВАНИЕ ЗАПИСИ" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1" 
                        x:Name="CloseButton"
                        Content="✕"
                        Background="Transparent"
                        BorderBrush="#CE7802"
                        BorderThickness="1"
                        Foreground="#CE7802"
                        Width="30"
                        Height="30"
                        FontSize="16"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="CloseButton_Click"/>
            </Grid>

            <!-- Форма (аналогично окну добавления) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Клиент *" Foreground="#CCCCCC" Margin="5 0 5 5" FontSize="14"/>
                    <ComboBox x:Name="ClientComboBox" Height="40" Background="#FF1E1E1E" 
                              BorderBrush="#FF333333" Foreground="White" DisplayMemberPath="FullName" 
                              SelectedValuePath="Id" Margin="0 0 0 15"/>

                    <TextBlock Text="Мастер *" Foreground="#CCCCCC" Margin="5 0 5 5" FontSize="14"/>
                    <ComboBox x:Name="EmployeeComboBox" Height="40" Background="#FF1E1E1E" 
                              BorderBrush="#FF333333" Foreground="White" DisplayMemberPath="FullName" 
                              SelectedValuePath="Id" Margin="0 0 0 15"/>

                    <TextBlock Text="Услуга *" Foreground="#CCCCCC" Margin="5 0 5 5" FontSize="14"/>
                    <ComboBox x:Name="ServiceComboBox" Height="40" Background="#FF1E1E1E" 
                              BorderBrush="#FF333333" Foreground="White" DisplayMemberPath="Name" 
                              SelectedValuePath="Id" SelectionChanged="ServiceComboBox_SelectionChanged" 
                              Margin="0 0 0 15"/>

                    <TextBlock Text="Стоимость" Foreground="#CCCCCC" Margin="5 0 5 5" FontSize="14"/>
                    <TextBox x:Name="PriceTextBox" Height="40" Background="#FF1E1E1E" 
                             BorderBrush="#FF333333" Foreground="White" FontSize="14" 
                             Padding="10 5" IsReadOnly="True" Margin="0 0 0 15"/>

                    <TextBlock Text="Дата *" Foreground="#CCCCCC" Margin="5 0 5 5" FontSize="14"/>
                    <DatePicker x:Name="AppointmentDatePicker" Background="#FF1E1E1E" 
                                Foreground="White" BorderBrush="#FF333333" Height="40" 
                                Margin="0 0 0 15"/>

                    <TextBlock Text="Время *" Foreground="#CCCCCC" Margin="5 0 5 5" FontSize="14"/>
                    <TextBox x:Name="TimeTextBox" Height="40" Background="#FF1E1E1E" 
                             BorderBrush="#FF333333" Foreground="White" FontSize="14" 
                             Padding="10 5" Margin="0 0 0 15"/>

                    <TextBlock Text="Статус *" Foreground="#CCCCCC" Margin="5 0 5 5" FontSize="14"/>
                    <ComboBox x:Name="StatusComboBox" Height="40" Background="#FF1E1E1E" 
                              BorderBrush="#FF333333" Foreground="White" DisplayMemberPath="Name" 
                              SelectedValuePath="Id" Margin="0 0 0 15"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Кнопки -->
            <Grid Grid.Row="2" Margin="0 20 0 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="CancelButton" Content="Отмена" Height="45"
                        Background="Transparent" BorderBrush="#FF333333" BorderThickness="2"
                        Foreground="#CCCCCC" FontSize="16" FontWeight="Bold" Cursor="Hand"
                        Margin="0 0 5 0" Click="CancelButton_Click"/>

                <Button Grid.Column="1" x:Name="SaveButton" Content="Сохранить" Height="45"
                        Background="#CE7802" BorderThickness="0" Foreground="White"
                        FontSize="16" FontWeight="Bold" Cursor="Hand"
                        Margin="5 0 0 0" Click="SaveButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>