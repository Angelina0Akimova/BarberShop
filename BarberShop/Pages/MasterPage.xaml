<Page x:Class="BarberShop.Pages.MasterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="1080" d:DesignWidth="1920"
      Title="MasterPage"
      Background="#FF090909"
      Loaded="Page_Loaded">

    <Page.Resources>
        <!-- Стиль для заголовков секций -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0 20 0 20"/>
        </Style>

        <!-- Стиль для карточки записи -->
        <Style x:Key="AppointmentCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
        </Style>

        <!-- Стиль для кнопок действий с иконками -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#CE7802"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#CE7802"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2"/>
        </Style>

        <!-- Стиль для основной кнопки действия (Добавить запись) -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="#CE7802"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20 10"/>
        </Style>

        <!-- Стиль для кнопок выбора периода -->
        <Style x:Key="PeriodButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#CE7802"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15 8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#CE7802"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF090909" Offset="0"/>
                    <GradientStop Color="#FF1A1A1A" Offset="0.5"/>
                    <GradientStop Color="#FF090909" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <StackPanel Margin="50">

                <!-- Верхняя панель с логотипом, приветствием и кнопками -->
                <Grid Margin="0 0 0 30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Логотип слева -->
                    <Image Grid.Column="0" 
                           Source="/Iamges/logo.png" 
                           Height="60" 
                           Width="60"
                           Margin="0 0 20 0"/>

                    <!-- Приветствие по центру -->
                    <TextBlock Grid.Column="1" 
                               x:Name="WelcomeTextBlock"
                               Text="Добро пожаловать, Мастер!"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <!-- Кнопки справа -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <!-- Кнопка добавления записи -->
                        <Button x:Name="AddAppointmentButton"
                                Style="{StaticResource ActionButtonStyle}"
                                Width="216"
                                Margin="0 0 15 0"
                                Click="AddAppointmentButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="➕" FontSize="18" Margin="0 0 10 0"/>
                                <TextBlock Text="Добавить запись"/>
                            </StackPanel>
                        </Button>

                        <!-- Кнопка выхода -->
                        <Button x:Name="LogoutButton"
                                Content="🚪 Выйти"
                                Background="Transparent"
                                BorderBrush="#CE7802"
                                BorderThickness="2"
                                Foreground="#CE7802"
                                FontSize="16"
                                FontWeight="Bold"
                                Padding="20 10"
                                Cursor="Hand"
                                Click="LogoutButton_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Секция с данными мастера -->
                <Border Style="{StaticResource AppointmentCardStyle}" Margin="0 0 0 20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Аватарка (заглушка) -->
                        <Border Grid.Column="0"
                                Background="#CE7802"
                                Width="80"
                                Height="80"
                                CornerRadius="40"
                                Margin="0 0 20 0">
                            <TextBlock Text="💇"
                                       FontSize="40"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Информация о мастере -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="MasterNameText"
                                       Text="Иванов Иван"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <WrapPanel Margin="0 5 0 0">
                                <TextBlock Text="📞 " Foreground="#CE7802"/>
                                <TextBlock x:Name="MasterPhoneText"
                                           Text="+7 (999) 123-45-67"
                                           FontSize="16"
                                           Foreground="#CCCCCC"
                                           Margin="0 0 20 0"/>
                                <TextBlock Text="✉️ " Foreground="#CE7802"/>
                                <TextBlock x:Name="MasterEmailText"
                                           Text="master@barbershop.ru"
                                           FontSize="16"
                                           Foreground="#CCCCCC"/>
                            </WrapPanel>
                            <WrapPanel Margin="0 5 0 0">
                                <TextBlock Text="📅 В штабе с: " Foreground="#CCCCCC"/>
                                <TextBlock x:Name="MasterHireDateText"
                                           Text="15.01.2023"
                                           FontSize="14"
                                           Foreground="#CE7802"
                                           FontWeight="Bold"/>
                                <TextBlock Text="  |  💬 " Foreground="#CCCCCC" Margin="10 0 0 0"/>
                                <TextBlock x:Name="MasterBioText"
                                           Text="Опытный мастер"
                                           FontSize="14"
                                           Foreground="White"
                                           TextWrapping="Wrap"/>
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Блок статистики -->
                <Border Style="{StaticResource AppointmentCardStyle}" Margin="0 0 0 20">
                    <StackPanel>
                        <TextBlock Text="📊 СТАТИСТИКА ЗА ПЕРИОД" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   Margin="0 0 0 15"/>

                        <!-- Выбор периода -->
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
                            <RadioButton x:Name="PeriodWeekRadio" 
                                         Content="Неделя" 
                                         Style="{StaticResource PeriodButtonStyle}"
                                         IsChecked="True"
                                         GroupName="PeriodGroup"
                                         Checked="PeriodRadio_Checked" Height="28" Width="63"/>
                            <RadioButton x:Name="PeriodMonthRadio" 
                                         Content="Месяц" 
                                         Style="{StaticResource PeriodButtonStyle}"
                                         Margin="10 0 0 0"
                                         GroupName="PeriodGroup"
                                         Checked="PeriodRadio_Checked" Width="62"/>
                        </StackPanel>

                        <!-- Показатели статистики -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Количество клиентов" 
                                           Foreground="#999999" 
                                           FontSize="14"/>
                                <TextBlock x:Name="StatsClientsCountText" 
                                           Text="0" 
                                           Foreground="#CE7802" 
                                           FontSize="32" 
                                           FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Выручка" 
                                           Foreground="#999999" 
                                           FontSize="14"/>
                                <TextBlock x:Name="StatsRevenueText" 
                                           Text="0 ₽" 
                                           Foreground="#CE7802" 
                                           FontSize="32" 
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Актуальные записи (Запланированные) -->
                <TextBlock Text="📅 АКТУАЛЬНЫЕ ЗАПИСИ" Style="{StaticResource SectionTitleStyle}"/>

                <ItemsControl x:Name="UpcomingAppointmentsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource AppointmentCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Информация о записи -->
                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <!-- Клиент и телефон -->
                                        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                                            <TextBlock Text="👤 " Foreground="#CE7802" FontSize="16"/>
                                            <TextBlock Text="{Binding ClientName}" 
                                                       FontSize="18" 
                                                       FontWeight="Bold" 
                                                       Foreground="White"
                                                       Margin="0 0 10 0"/>
                                            <TextBlock Text="📞 " Foreground="#CE7802" FontSize="16"/>
                                            <TextBlock Text="{Binding ClientPhone}" 
                                                       Foreground="#CCCCCC" 
                                                       FontSize="16"/>
                                        </StackPanel>

                                        <!-- Детали записи -->
                                        <WrapPanel Margin="0 0 0 10">
                                            <Border Background="#FF2A2A2A"
                                                    CornerRadius="5"
                                                    Padding="10 5"
                                                    Margin="0 0 10 5">
                                                <TextBlock>
                                                    <Run Text="💈 " Foreground="#CE7802"/>
                                                    <Run Text="{Binding ServiceName}" Foreground="White"/>
                                                </TextBlock>
                                            </Border>

                                            <Border Background="#FF2A2A2A"
                                                    CornerRadius="5"
                                                    Padding="10 5"
                                                    Margin="0 0 10 5">
                                                <TextBlock>
                                                    <Run Text="⏰ " Foreground="#CE7802"/>
                                                    <Run Text="{Binding Time}" Foreground="White"/>
                                                </TextBlock>
                                            </Border>

                                            <Border Background="#4CAF50"
                                                    CornerRadius="5"
                                                    Padding="10 5"
                                                    Margin="0 0 10 5">
                                                <TextBlock Text="{Binding Price}" 
                                                           Foreground="White" 
                                                           FontWeight="Bold"/>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>

                                    <!-- Кнопки действий -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" 
                                                Orientation="Horizontal"
                                                VerticalAlignment="Top">
                                        <Button Style="{StaticResource IconButtonStyle}"
                                                ToolTip="Редактировать"
                                                Tag="{Binding AppointmentID}"
                                                Click="EditAppointmentButton_Click">
                                            <TextBlock Text="✏️" FontFamily="Segoe UI Emoji"/>
                                        </Button>
                                        <Button Style="{StaticResource IconButtonStyle}"
                                                ToolTip="Удалить"
                                                Tag="{Binding AppointmentID}"
                                                Click="DeleteAppointmentButton_Click">
                                            <TextBlock Text="🗑️" FontFamily="Segoe UI Emoji"/>
                                        </Button>
                                    </StackPanel>

                                    <!-- Статус (внизу) -->
                                    <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                            Background="#4CAF50"
                                            CornerRadius="5"
                                            Padding="10 5"
                                            Margin="0 10 0 0"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="Запланировано"
                                                   Foreground="White"
                                                   FontSize="12"
                                                   FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Сообщение, если нет актуальных записей -->
                <TextBlock x:Name="NoUpcomingAppointmentsText"
                           Text="Нет актуальных записей"
                           Foreground="#666666"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Margin="0 20"
                           Visibility="Collapsed"/>

                <!-- Прошедшие записи -->
                <TextBlock Text="📜 ПРОШЕДШИЕ ЗАПИСИ" Style="{StaticResource SectionTitleStyle}"/>

                <ItemsControl x:Name="PastAppointmentsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource AppointmentCardStyle}" Opacity="0.7">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Информация о записи -->
                                    <StackPanel Grid.Row="0">
                                        <!-- Клиент -->
                                        <StackPanel Orientation="Horizontal" Margin="0 0 0 5">
                                            <TextBlock Text="👤 " Foreground="#CE7802" FontSize="14"/>
                                            <TextBlock Text="{Binding ClientName}" 
                                                       FontSize="16" 
                                                       FontWeight="Bold" 
                                                       Foreground="White"/>
                                        </StackPanel>

                                        <!-- Детали -->
                                        <WrapPanel>
                                            <Border Background="#FF2A2A2A"
                                                    CornerRadius="5"
                                                    Padding="8 3"
                                                    Margin="0 0 5 5">
                                                <TextBlock Text="{Binding ServiceName}" Foreground="#CCCCCC" FontSize="13"/>
                                            </Border>
                                            <Border Background="#FF2A2A2A"
                                                    CornerRadius="5"
                                                    Padding="8 3"
                                                    Margin="0 0 5 5">
                                                <TextBlock Text="{Binding Date}" Foreground="#CCCCCC" FontSize="13"/>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>

                                    <!-- Статус -->
                                    <Border Grid.Row="1"
                                            Background="{Binding StatusColor}"
                                            CornerRadius="5"
                                            Padding="8 3"
                                            Margin="0 5 0 0"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="White"
                                                   FontSize="11"
                                                   FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Сообщение, если нет прошедших записей -->
                <TextBlock x:Name="NoPastAppointmentsText"
                           Text="Нет прошедших записей"
                           Foreground="#666666"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Margin="0 20"
                           Visibility="Collapsed"/>

                <!-- Нижний колонтитул -->
                <Border Background="#FF1E1E1E" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="0 30 0 0">
                    <TextBlock Text="© 2026 BARBERSHOP «ПОДДУБНЫЙ». Все права защищены." 
                               Foreground="#666666" 
                               HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>