<Window x:Class="BarberShop.Pages.AddClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление нового клиента"
        Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#FF090909"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="15" Background="#FF141414" BorderBrush="#CE7802" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Grid Grid.Row="0" Margin="0 0 0 20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="ДОБАВЛЕНИЕ КЛИЕНТА" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1" 
                        x:Name="CloseButton"
                        Content="✕"
                        Background="Transparent"
                        BorderBrush="#CE7802"
                        BorderThickness="1"
                        Foreground="#CE7802"
                        Width="30"
                        Height="30"
                        FontSize="16"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="CloseButton_Click"/>
            </Grid>

            <!-- Форма -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Фамилия -->
                    <TextBlock Text="Фамилия *" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <TextBox x:Name="LastNameTextBox" 
                             Height="40" 
                             Background="#FF1E1E1E" 
                             BorderBrush="#FF333333" 
                             BorderThickness="1" 
                             Foreground="White" 
                             FontSize="14" 
                             Padding="10 5" 
                             Margin="0 0 0 15"/>

                    <!-- Имя -->
                    <TextBlock Text="Имя *" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <TextBox x:Name="FirstNameTextBox" 
                             Height="40" 
                             Background="#FF1E1E1E" 
                             BorderBrush="#FF333333" 
                             BorderThickness="1" 
                             Foreground="White" 
                             FontSize="14" 
                             Padding="10 5" 
                             Margin="0 0 0 15"/>

                    <!-- Отчество (необязательно) -->
                    <TextBlock Text="Отчество" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <TextBox x:Name="MiddleNameTextBox" 
                             Height="40" 
                             Background="#FF1E1E1E" 
                             BorderBrush="#FF333333" 
                             BorderThickness="1" 
                             Foreground="White" 
                             FontSize="14" 
                             Padding="10 5" 
                             Margin="0 0 0 15"/>

                    <!-- Телефон -->
                    <TextBlock Text="Телефон *" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <TextBox x:Name="PhoneTextBox" 
                             Height="40" 
                             Background="#FF1E1E1E" 
                             BorderBrush="#FF333333" 
                             BorderThickness="1" 
                             Foreground="White" 
                             FontSize="14" 
                             Padding="10 5" 
                             Margin="0 0 0 15"/>

                    <!-- Email -->
                    <TextBlock Text="Email" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <TextBox x:Name="EmailTextBox" 
                             Height="40" 
                             Background="#FF1E1E1E" 
                             BorderBrush="#FF333333" 
                             BorderThickness="1" 
                             Foreground="White" 
                             FontSize="14" 
                             Padding="10 5" 
                             Margin="0 0 0 15"/>

                    <!-- Логин -->
                    <TextBlock Text="Логин *" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <TextBox x:Name="LoginTextBox" 
                             Height="40" 
                             Background="#FF1E1E1E" 
                             BorderBrush="#FF333333" 
                             BorderThickness="1" 
                             Foreground="White" 
                             FontSize="14" 
                             Padding="10 5" 
                             Margin="0 0 0 15"/>

                    <!-- Пароль -->
                    <TextBlock Text="Пароль *" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <PasswordBox x:Name="PasswordBox" 
                                 Height="40" 
                                 Background="#FF1E1E1E" 
                                 BorderBrush="#FF333333" 
                                 BorderThickness="1" 
                                 Foreground="White" 
                                 FontSize="14" 
                                 Padding="10 5" 
                                 Margin="0 0 0 15"/>

                    <!-- Подтверждение пароля -->
                    <TextBlock Text="Подтверждение пароля *" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <PasswordBox x:Name="ConfirmPasswordBox" 
                                 Height="40" 
                                 Background="#FF1E1E1E" 
                                 BorderBrush="#FF333333" 
                                 BorderThickness="1" 
                                 Foreground="White" 
                                 FontSize="14" 
                                 Padding="10 5" 
                                 Margin="0 0 0 15"/>

                    <!-- Дата рождения -->
                    <TextBlock Text="Дата рождения" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <DatePicker x:Name="BirthDatePicker"
                                Background="#FF1E1E1E"
                                Foreground="White"
                                BorderBrush="#FF333333"
                                Height="40"
                                Margin="0 0 0 15"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Кнопки -->
            <Grid Grid.Row="2" Margin="0 20 0 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" 
                        x:Name="CancelButton"
                        Content="Отмена"
                        Height="45"
                        Background="Transparent"
                        BorderBrush="#FF333333"
                        BorderThickness="2"
                        Foreground="#CCCCCC"
                        FontSize="16"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Margin="0 0 5 0"
                        Click="CancelButton_Click"/>

                <Button Grid.Column="1" 
                        x:Name="SaveButton"
                        Content="Сохранить"
                        Height="45"
                        Background="#CE7802"
                        BorderThickness="0"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Margin="5 0 0 0"
                        Click="SaveButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>