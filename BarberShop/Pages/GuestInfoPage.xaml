<Page x:Class="BarberShop.Pages.GuestInfoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="1080" d:DesignWidth="1920"
      Title="GuestInfoPage"
      Background="#FF090909"
      ScrollViewer.VerticalScrollBarVisibility="Auto"
      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

    <!-- Добавляем ресурсы для стилей -->
    <Page.Resources>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="36"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0 0 0 30"/>
        </Style>

        <Style x:Key="ContactTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0 5 0 5"/>
        </Style>

        <Style x:Key="ServiceItemStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0 0 0 10"/>
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <Grid>
            <!-- Фоновый градиент -->
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF090909" Offset="0"/>
                    <GradientStop Color="#FF1A1A1A" Offset="0.5"/>
                    <GradientStop Color="#FF090909" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <StackPanel>

                <!-- Hero секция с логотипом и кнопкой назад -->
                <Grid Height="400">
                    <Grid.Background>
                        <ImageBrush ImageSource="/Iamges/images.jpg" Opacity="0.3" Stretch="UniformToFill"/>
                    </Grid.Background>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Логотип -->
                        <Image Source="/Iamges/logo.png" Height="150" Width="150" Margin="0 0 0 20" 
                               HorizontalAlignment="Center"/>

                        <!-- Название - убираем LetterSpacing -->
                        <TextBlock Text="ПОДДУБНЫЙ" 
                                   FontSize="48" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="BARBERSHOP" 
                                   FontSize="24" 
                                   Foreground="#CE7802" 
                                   HorizontalAlignment="Center" 
                                   Margin="0 10 0 0"/>
                    </StackPanel>

                    <!-- Кнопка назад -->
                    <Button Content="← Назад" 
                            Background="Transparent" 
                            BorderBrush="#CE7802" 
                            BorderThickness="1" 
                            Foreground="#CE7802" 
                            Width="100" 
                            Height="35" 
                            HorizontalAlignment="Left" 
                            VerticalAlignment="Top"
                            Margin="20"
                            Click="BackButton_Click"/>
                </Grid>

                <!-- Основной контент -->
                <StackPanel Margin="50 30 50 30">

                    <!-- Секция "О нас" -->
                    <TextBlock Text="О НАС" 
                               Style="{StaticResource SectionTitleStyle}"/>

                    <Border Background="#FF1E1E1E" 
                            CornerRadius="10" 
                            Padding="30" 
                            Margin="0 0 0 40">
                        <TextBlock TextWrapping="Wrap" 
                                   Foreground="#CCCCCC" 
                                   FontSize="16" 
                                   LineHeight="28">
                            Не так давно на вопрос «Где можно сделать мужскую стрижку?» - был возможен только один ответ: в парикмахерской.

В некоторых из них были мужские залы, где на стенах висели фотографии мужчин с модельными стрижками, а в прейскуранте значилась такая услуга, как бритье. Со временем подобные парикмахерские практически исчезли из нашей жизни, индустрия красоты была отдана на откуп женщинам. Мужчинам же только и оставалось, как посетить женского мастера, который умел делать и мужские стрижки.

Однако теперь ситуация изменилась, во многих городах появились барбершопы – парикмахерские для мужчин.

Что же представляет из себя НАШЕ заведение? Попробуем разобраться.

Итак, барбершоп «Поддубный» — мужская территория с характером. Мы не культивируем и не поддерживаем какую либо моду, каждый гость для нас уникален. «Поддубный» это то место, где вы получите не только качественную стрижку и шикарно оформленную бороду, здесь вы проведете время в удовольствие и с пользой.
                        </TextBlock>
                    </Border>

                    <!-- Секция "Услуги" -->
                    <TextBlock Text="УСЛУГИ" 
                               Style="{StaticResource SectionTitleStyle}"/>

                    <Grid Margin="0 0 0 40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Левая колонка с услугами -->
                        <StackPanel Grid.Column="0" Margin="0 0 15 0">

                            <!-- Заголовок -->
                            <Border Background="#FF1E1E1E" 
                                    CornerRadius="10" 
                                    Padding="20" 
                                    Margin="0 0 0 20">
                                <TextBlock Text="ПРАЙС-ЛИСТ" 
                                           FontSize="24" 
                                           FontWeight="Bold" 
                                           Foreground="#CE7802" 
                                           HorizontalAlignment="Center"/>
                            </Border>

                            <!-- Услуга 1: Классическая стрижка -->
                            <Border Style="{StaticResource ServiceItemStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Иконка -->
                                    <Image Source="/Iamges/038-chair-150x150.png" 
                                           Width="40" 
                                           Height="40" 
                                           Margin="0 0 15 0"/>

                                    <!-- Название услуги -->
                                    <TextBlock Grid.Column="1" 
                                               Text="Классическая стрижка" 
                                               Foreground="White" 
                                               FontSize="18" 
                                               VerticalAlignment="Center"/>

                                    <!-- Цена -->
                                    <TextBlock Grid.Column="2" 
                                               Text="от 1490 ₽" 
                                               Foreground="#CE7802" 
                                               FontSize="18" 
                                               FontWeight="Bold" 
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Услуга 2: Стрижка под насадку -->
                            <Border Style="{StaticResource ServiceItemStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Иконка -->
                                    <Image Source="/Iamges/razor-150x150.png" 
                                           Width="40" 
                                           Height="40" 
                                           Margin="0 0 15 0"/>

                                    <!-- Название услуги -->
                                    <TextBlock Grid.Column="1" 
                                               Text="Стрижка под насадку" 
                                               Foreground="White" 
                                               FontSize="18" 
                                               VerticalAlignment="Center"/>

                                    <!-- Цена -->
                                    <TextBlock Grid.Column="2" 
                                               Text="от 1090 ₽" 
                                               Foreground="#CE7802" 
                                               FontSize="18" 
                                               FontWeight="Bold" 
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Услуга 3: Королевское бритьё -->
                            <Border Style="{StaticResource ServiceItemStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Иконка -->
                                    <Image Source="/Iamges/009-razor-1-150x150.png" 
                                           Width="40" 
                                           Height="40" 
                                           Margin="0 0 15 0"/>

                                    <!-- Название услуги -->
                                    <TextBlock Grid.Column="1" 
                                               Text="Королевское бритьё" 
                                               Foreground="White" 
                                               FontSize="18" 
                                               VerticalAlignment="Center"/>

                                    <!-- Цена -->
                                    <TextBlock Grid.Column="2" 
                                               Text="от 1990 ₽" 
                                               Foreground="#CE7802" 
                                               FontSize="18" 
                                               FontWeight="Bold" 
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Услуга 4: Бритьё головы -->
                            <Border Style="{StaticResource ServiceItemStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Иконка -->
                                    <Image Source="/Iamges/031-cream-1-150x150.png" 
                                           Width="40" 
                                           Height="40" 
                                           Margin="0 0 15 0"/>

                                    <!-- Название услуги -->
                                    <TextBlock Grid.Column="1" 
                                               Text="Бритьё головы" 
                                               Foreground="White" 
                                               FontSize="18" 
                                               VerticalAlignment="Center"/>

                                    <!-- Цена -->
                                    <TextBlock Grid.Column="2" 
                                               Text=" от 1290 ₽" 
                                               Foreground="#CE7802" 
                                               FontSize="18" 
                                               FontWeight="Bold" 
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Услуга 5: Детская стрижка -->
                            <Border Style="{StaticResource ServiceItemStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Иконка -->
                                    <Image Source="/Iamges/son-150x150.png" 
                                           Width="40" 
                                           Height="40" 
                                           Margin="0 0 15 0"/>

                                    <!-- Название услуги -->
                                    <TextBlock Grid.Column="1" 
                                               Text="Детская стрижка" 
                                               Foreground="White" 
                                               FontSize="18" 
                                               VerticalAlignment="Center"/>

                                    <!-- Цена -->
                                    <TextBlock Grid.Column="2" 
                                               Text=" от 1190 ₽" 
                                               Foreground="#CE7802" 
                                               FontSize="18" 
                                               FontWeight="Bold" 
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Услуга 6: Коррекция бороды -->
                            <Border Style="{StaticResource ServiceItemStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Иконка -->
                                    <Image Source="/Iamges/013-beard-150x150.png" 
                                           Width="40" 
                                           Height="40" 
                                           Margin="0 0 15 0"/>

                                    <!-- Название услуги -->
                                    <TextBlock Grid.Column="1" 
                                               Text="Коррекция бороды" 
                                               Foreground="White" 
                                               FontSize="18" 
                                               VerticalAlignment="Center"/>

                                    <!-- Цена -->
                                    <TextBlock Grid.Column="2" 
                                               Text="от 1290 ₽" 
                                               Foreground="#CE7802" 
                                               FontSize="18" 
                                               FontWeight="Bold" 
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Правая колонка с изображением -->
                        <StackPanel Grid.Column="1" Margin="15 0 0 0">
                            <Border Background="#FF1E1E1E" 
                                    CornerRadius="10" 
                                    Height="500">
                                <Image Source="/Iamges/pngtree-hairdressers-special-tool-scissors-comb-image_823326.jpg" 
                                       Stretch="UniformToFill"
                                       Opacity="0.9"/>
                            </Border>

                            <!-- Дополнительная информация -->
                            <Border Background="#FF1E1E1E" 
                                    CornerRadius="10" 
                                    Padding="20" 
                                    Margin="0 15 0 0">
                                <StackPanel>
                                    <TextBlock Text="✨ ПРЕИМУЩЕСТВА" 
                                               Foreground="#CE7802" 
                                               FontSize="18" 
                                               FontWeight="Bold" 
                                               Margin="0 0 0 15"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Преимущество 1 -->
                                        <Image Grid.Row="0" Grid.Column="0" 
                                               Source="/Iamges/009-razor-1-150x150.png" 
                                               Width="25" Height="25" 
                                               Margin="0 0 10 10"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" 
                                                   Text="Профессиональные мастера" 
                                                   Foreground="White" 
                                                   Margin="0 0 0 10"/>

                                        <!-- Преимущество 2 -->
                                        <Image Grid.Row="1" Grid.Column="0" 
                                               Source="/Iamges/031-cream-1-150x150.png" 
                                               Width="25" Height="25" 
                                               Margin="0 0 10 10"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" 
                                                   Text="Премиальная косметика" 
                                                   Foreground="White" 
                                                   Margin="0 0 0 10"/>

                                        <!-- Преимущество 3 -->
                                        <Image Grid.Row="2" Grid.Column="0" 
                                               Source="/Iamges/038-chair-150x150.png" 
                                               Width="25" Height="25" 
                                               Margin="0 0 10 0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" 
                                                   Text="Уютная атмосфера" 
                                                   Foreground="White"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Секция "Контакты" -->
                    <TextBlock Text="КОНТАКТЫ" 
                               Style="{StaticResource SectionTitleStyle}"/>

                    <Border Background="#FF1E1E1E" 
                            CornerRadius="10" 
                            Padding="30" 
                            Margin="0 0 0 40">
                        <StackPanel>
                            <!-- Первый ряд контактов -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Колонка 1 -->
                                <StackPanel Grid.Column="0" Margin="0 0 15 0">
                                    <Border Background="#CE7802" 
                                            Width="50" 
                                            Height="50" 
                                            CornerRadius="25" 
                                            Margin="0 0 0 15">
                                        <TextBlock Text="📍" 
                                                   FontSize="24" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Старо-Петергофский пр. 37" 
                                               Style="{StaticResource ContactTextStyle}"/>
                                    <TextBlock Text="8(812)903-37-43" 
                                               Style="{StaticResource ContactTextStyle}"
                                               Foreground="#CE7802"/>
                                    <TextBlock Text="м. Нарвская" 
                                               Style="{StaticResource ContactTextStyle}"/>
                                </StackPanel>

                                <!-- Колонка 2 -->
                                <StackPanel Grid.Column="1" Margin="15 0 15 0">
                                    <Border Background="#CE7802" 
                                            Width="50" 
                                            Height="50" 
                                            CornerRadius="25" 
                                            Margin="0 0 0 15">
                                        <TextBlock Text="📍" 
                                                   FontSize="24" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Петергофское шоссе, 51" 
                                               Style="{StaticResource ContactTextStyle}"/>
                                    <TextBlock Text="8(812)903-83-21" 
                                               Style="{StaticResource ContactTextStyle}"
                                               Foreground="#CE7802"/>
                                    <TextBlock Text="ТРК &quot;Жемчужная Плаза&quot;" 
                                               Style="{StaticResource ContactTextStyle}"/>
                                </StackPanel>

                                <!-- Колонка 3 -->
                                <StackPanel Grid.Column="2" Margin="15 0 15 0">
                                    <Border Background="#CE7802" 
                                            Width="50" 
                                            Height="50" 
                                            CornerRadius="25" 
                                            Margin="0 0 0 15">
                                        <TextBlock Text="📍" 
                                                   FontSize="24" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Академика Павлова, 7" 
                                               Style="{StaticResource ContactTextStyle}"/>
                                    <TextBlock Text="8(812)907-11-37" 
                                               Style="{StaticResource ContactTextStyle}"
                                               Foreground="#CE7802"/>
                                    <TextBlock Text="м. Петроградская" 
                                               Style="{StaticResource ContactTextStyle}"/>
                                </StackPanel>

                                <!-- Колонка 4 -->
                                <StackPanel Grid.Column="3" Margin="15 0 0 0">
                                    <Border Background="#CE7802" 
                                            Width="50" 
                                            Height="50" 
                                            CornerRadius="25" 
                                            Margin="0 0 0 15">
                                        <TextBlock Text="📍" 
                                                   FontSize="24" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="пр-т Героев 31" 
                                               Style="{StaticResource ContactTextStyle}"/>
                                    <TextBlock Text="8(812) 999-82-29" 
                                               Style="{StaticResource ContactTextStyle}"
                                               Foreground="#CE7802"/>
                                    <TextBlock Text="ЖК &quot;Legenda на Героев&quot;" 
                                               Style="{StaticResource ContactTextStyle}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Второй ряд контактов -->
                            <Grid Margin="0 30 0 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Колонка 5 -->
                                <StackPanel Grid.Column="0" Margin="0 0 15 0">
                                    <Border Background="#CE7802" 
                                            Width="50" 
                                            Height="50" 
                                            CornerRadius="25" 
                                            Margin="0 0 0 15">
                                        <TextBlock Text="📍" 
                                                   FontSize="24" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Новгородский пр., 6" 
                                               Style="{StaticResource ContactTextStyle}"/>
                                    <TextBlock Text="8(931)276-47-15" 
                                               Style="{StaticResource ContactTextStyle}"
                                               Foreground="#CE7802"/>
                                    <TextBlock Text="п.Шушары" 
                                               Style="{StaticResource ContactTextStyle}"/>
                                </StackPanel>

                                <!-- Колонка 6 -->
                                <StackPanel Grid.Column="1" Margin="15 0 15 0">
                                    <Border Background="#CE7802" 
                                            Width="50" 
                                            Height="50" 
                                            CornerRadius="25" 
                                            Margin="0 0 0 15">
                                        <TextBlock Text="📍" 
                                                   FontSize="24" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Парашютная улица, 61к1" 
                                               Style="{StaticResource ContactTextStyle}"/>
                                    <TextBlock Text="8(931)303-08-39" 
                                               Style="{StaticResource ContactTextStyle}"
                                               Foreground="#CE7802"/>
                                    <TextBlock Text="м. Комендантский пр." 
                                               Style="{StaticResource ContactTextStyle}"/>
                                </StackPanel>

                                <!-- Колонка 7 -->
                                <StackPanel Grid.Column="2" Margin="15 0 15 0">
                                    <Border Background="#CE7802" 
                                            Width="50" 
