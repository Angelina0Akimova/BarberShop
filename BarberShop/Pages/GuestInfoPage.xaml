                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Нижний колонтитул -->
                    <Border Background="#FF1E1E1E" 
                            CornerRadius="10" 
                            Padding="20" 
                            Margin="0 0 0 30">
                        <TextBlock Text="© 2026 BARBERSHOP «ПОДДУБНЫЙ». Все права защищены." 
                                   Foreground="#666666" 
                                   HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>