<Page x:Class="BarberShop.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BarberShop.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="1080" d:DesignWidth="1920"
      Title="ReportsPage"
      Background="#FF090909"
      Loaded="Page_Loaded">

    <Page.Resources>
        <!-- Стиль для заголовков секций -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0 20 0 15"/>
        </Style>

        <!-- Стиль для карточек отчетов -->
        <Style x:Key="ReportCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0 0 0 20"/>
        </Style>

        <!-- Стиль для кнопок действий -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#CE7802"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="15 0"/>
        </Style>

        <!-- Стиль для кнопок выгрузки -->
        <Style x:Key="ExportButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#CE7802"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#CE7802"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="10 0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF2A2A2A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для текста в отчетах -->
        <Style x:Key="ReportTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0 5 0 5"/>
        </Style>

        <!-- Стиль для числовых значений -->
        <Style x:Key="ReportValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CE7802"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0 5 0 5"/>
        </Style>

        <!-- Стиль для элемента списка услуг -->
        <Style x:Key="ServiceItemStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Margin" Value="0 0 0 5"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Фоновый градиент -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF090909" Offset="0"/>
                <GradientStop Color="#FF1A1A1A" Offset="0.5"/>
                <GradientStop Color="#FF090909" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">

                <!-- Верхняя панель с логотипом, заголовком и кнопкой выхода -->
                <Grid Margin="0 0 0 30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Логотип слева -->
                    <Image Grid.Column="0" 
                           Source="/Iamges/logo.png" 
                           Height="60" 
                           Width="60"
                           Margin="0 0 20 0"/>

                    <!-- Заголовок по центру -->
                    <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="ОТЧЕТЫ" 
                                  FontSize="32"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"/>
                        <TextBlock x:Name="AdminInfoText"
                                  Text="Администратор: Загрузка..."
                                  Foreground="#CE7802"
                                  FontSize="16"
                                  HorizontalAlignment="Center"
                                  Margin="0 5 0 0"/>
                    </StackPanel>

                    <!-- Кнопка выхода -->
                    <Button Grid.Column="2" 
                            x:Name="LogoutButton"
                            Content="🚪 Выйти"
                            Background="Transparent"
                            BorderBrush="#CE7802"
                            BorderThickness="2"
                            Foreground="#CE7802"
                            FontSize="16"
                            FontWeight="Bold"
                            Padding="20 10"
                            Cursor="Hand"
                            Click="LogoutButton_Click"/>
                </Grid>

                <!-- Выбор периода для всех отчетов -->
                <Border Background="#FF141414" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="0 0 0 30">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" 
                                   Text="Период:" 
                                   Foreground="White" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0 0 20 0"/>

                        <TextBlock Grid.Column="1" 
                                   Text="С:" 
                                   Foreground="#CCCCCC" 
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0 0 10 0"/>

                        <DatePicker Grid.Column="2" 
                                    x:Name="StartDatePicker"
                                    Background="#FF1E1E1E"
                                    Foreground="White"
                                    BorderBrush="#FF333333"
                                    Height="35"
                                    Width="150"
                                    Margin="0 0 20 0"
                                    SelectedDateChanged="DatePicker_SelectedDateChanged">
                            <DatePicker.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF1E1E1E"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="White"/>
                            </DatePicker.Resources>
                        </DatePicker>

                        <TextBlock Grid.Column="3" 
                                   Text="По:" 
                                   Foreground="#CCCCCC" 
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0 0 10 0"/>

                        <DatePicker Grid.Column="4" 
                                    x:Name="EndDatePicker"
                                    Background="#FF1E1E1E"
                                    Foreground="White"
                                    BorderBrush="#FF333333"
                                    Height="35"
                                    Width="150"
                                    SelectedDateChanged="DatePicker_SelectedDateChanged">
                            <DatePicker.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF1E1E1E"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="White"/>
                            </DatePicker.Resources>
                        </DatePicker>
                    </Grid>
                </Border>

                <!-- Отчет 1: Выручка за период -->
                <Border Style="{StaticResource ReportCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Заголовок -->
                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                   Text="💰 ВЫРУЧКА ЗА ПЕРИОД" 
                                   FontSize="20" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   Margin="0 0 0 15"/>

                        <!-- Кнопка выгрузки -->
                        <Button Grid.Row="0" Grid.Column="1" 
                                x:Name="ExportRevenueButton"
                                Style="{StaticResource ExportButtonStyle}"
                                Width="120"
                                Click="ExportRevenueButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📄" FontSize="14" Margin="0 0 5 0"/>
                                <TextBlock Text="PDF"/>
                            </StackPanel>
                        </Button>

                        <!-- Данные отчета -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="250"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" 
                                           Text="Общая выручка:" 
                                           Style="{StaticResource ReportTextStyle}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" 
                                           x:Name="TotalRevenueText"
                                           Text="0 ₽" 
                                           Style="{StaticResource ReportValueStyle}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" 
                                           Text="Количество выполненных записей:" 
                                           Style="{StaticResource ReportTextStyle}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" 
                                           x:Name="CompletedAppointmentsCountText"
                                           Text="0" 
                                           Style="{StaticResource ReportValueStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Отчет 2: Выручка по услугам -->
                <Border Style="{StaticResource ReportCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Заголовок -->
                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                   Text="📊 ВЫРУЧКА ПО УСЛУГАМ" 
                                   FontSize="20" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   Margin="0 0 0 15"/>

                        <!-- Кнопка выгрузки -->
                        <Button Grid.Row="0" Grid.Column="1" 
                                x:Name="ExportServicesButton"
                                Style="{StaticResource ExportButtonStyle}"
                                Width="120"
                                Click="ExportServicesButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📄" FontSize="14" Margin="0 0 5 0"/>
                                <TextBlock Text="PDF"/>
                            </StackPanel>
                        </Button>

                        <!-- Динамический список услуг -->
                        <ScrollViewer Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                                      MaxHeight="300" 
                                      VerticalScrollBarVisibility="Auto"
                                      Margin="0 0 0 15">
                            <ItemsControl x:Name="ServicesRevenueList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ServiceItemStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="120"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" 
                                                           Text="{Binding ServiceName}"
                                                           Foreground="White"
                                                           FontSize="14"
                                                           VerticalAlignment="Center"/>

                                                <TextBlock Grid.Column="1" 
                                                           Text="{Binding AppointmentCount, StringFormat='Количество: {0}'}"
                                                           Foreground="#CCCCCC"
                                                           FontSize="14"
                                                           VerticalAlignment="Center"/>

                                                <TextBlock Grid.Column="2" 
                                                           Text="{Binding TotalRevenue, StringFormat=' {0} р '}"
                                                           Foreground="#CE7802"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Итого по услугам -->
                        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0 15 0 0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" 
                                       Text="ИТОГО:" 
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="Bold"/>

                            <TextBlock Grid.Column="1" 
                                       x:Name="TotalServicesCountText"
                                       Text="0"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="Bold"/>

                            <TextBlock Grid.Column="2" 
                                       x:Name="TotalServicesRevenueText"
                                       Text="0 ₽"
                                       Foreground="#CE7802"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Отчет 3: Общее количество записей за период -->
                <Border Style="{StaticResource ReportCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Заголовок -->
                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                   Text="📅 КОЛИЧЕСТВО ЗАПИСЕЙ ЗА ПЕРИОД" 
                                   FontSize="20" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   Margin="0 0 0 15"/>

                        <!-- Кнопка выгрузки -->
                        <Button Grid.Row="0" Grid.Column="1" 
                                x:Name="ExportAppointmentsButton"
                                Style="{StaticResource ExportButtonStyle}"
                                Width="120"
                                Click="ExportAppointmentsButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📄" FontSize="14" Margin="0 0 5 0"/>
                                <TextBlock Text="PDF"/>
                            </StackPanel>
                        </Button>

                        <!-- Статистика по статусам -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
                            <Grid Margin="0 0 0 15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="250"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" 
                                           Text="Всего записей:" 
                                           Style="{StaticResource ReportTextStyle}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" 
                                           x:Name="TotalAppointmentsText"
                                           Text="0" 
                                           Style="{StaticResource ReportValueStyle}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" 
                                           Text="✓ Выполнено:" 
                                           Style="{StaticResource ReportTextStyle}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" 
                                           x:Name="CompletedAppointmentsText"
                                           Text="0" 
                                           Style="{StaticResource ReportValueStyle}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" 
                                           Text="⏳ Запланировано:" 
                                           Style="{StaticResource ReportTextStyle}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" 
                                           x:Name="ScheduledAppointmentsText"
                                           Text="0" 
                                           Style="{StaticResource ReportValueStyle}"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" 
                                           Text="❌ Отменено:" 
                                           Style="{StaticResource ReportTextStyle}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" 
                                           x:Name="CancelledAppointmentsText"
                                           Text="0" 
                                           Style="{StaticResource ReportValueStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Отчет 4: Дополнительная статистика -->
                <Border Style="{StaticResource ReportCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок -->
                        <TextBlock Grid.Row="0" 
                                   Text="📈 ДОПОЛНИТЕЛЬНАЯ СТАТИСТИКА" 
                                   FontSize="20" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   Margin="0 0 0 15"/>

                        <!-- Данные -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Левая колонка -->
                            <StackPanel Grid.Column="0" Margin="0 0 20 0">
                                <TextBlock Text="Средний чек:" Style="{StaticResource ReportTextStyle}"/>
                                <TextBlock x:Name="AverageBillText" 
                                           Text="0 ₽" 
                                           Style="{StaticResource ReportValueStyle}"/>

                                <TextBlock Text="Самый популярный мастер:" 
                                           Margin="0 20 0 5"
                                           Style="{StaticResource ReportTextStyle}"/>
                                <TextBlock x:Name="TopMasterText" 
                                           Text="-" 
                                           Style="{StaticResource ReportValueStyle}"/>
                                <TextBlock x:Name="TopMasterCountText" 
                                           Text="0 записей" 
                                           Foreground="#CCCCCC"
                                           FontSize="14"/>
                            </StackPanel>

                            <!-- Правая колонка -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Самая популярная услуга:" 
                                           Style="{StaticResource ReportTextStyle}"/>
                                <TextBlock x:Name="TopServiceText" 
                                           Text="-" 
                                           Style="{StaticResource ReportValueStyle}"/>
                                <TextBlock x:Name="TopServiceCountText" 
                                           Text="0 записей" 
                                           Foreground="#CCCCCC"
                                           FontSize="14"/>

                                <TextBlock Text="Самый активный клиент:" 
                                           Margin="0 20 0 5"
                                           Style="{StaticResource ReportTextStyle}"/>
                                <TextBlock x:Name="TopClientText" 
                                           Text="-" 
                                           Style="{StaticResource ReportValueStyle}"/>
                                <TextBlock x:Name="TopClientCountText" 
                                           Text="0 записей" 
                                           Foreground="#CCCCCC"
                                           FontSize="14"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Нижний колонтитул -->
                <Border Background="#FF1E1E1E" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="0 30 0 0">
                    <TextBlock Text="© 2026 BARBERSHOP «ПОДДУБНЫЙ». Все права защищены." 
                               Foreground="#666666" 
                               HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>