<Window x:Class="BarberShop.Pages.AddAppointmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление записи"
        Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#FF090909"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- Стиль для ComboBox чтобы текст в выпадающем списке был черным на белом фоне -->
        <Style x:Key="ContrastComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="BorderBrush" Value="#FF333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
            
            <!-- Стиль для выпадающего списка -->
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#CE7802"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFE5E5E5"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            
            <!-- Стиль для выпадающего списка -->
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <StackPanel Background="White"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для TextBox (черный фон, белый текст) -->
        <Style x:Key="ContrastTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="BorderBrush" Value="#FF333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10 5"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
        </Style>

        <!-- Стиль для DatePicker (черный фон, белый текст) -->
        <Style x:Key="ContrastDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF333333"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="15" Background="#FF141414" BorderBrush="#CE7802" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Grid Grid.Row="0" Margin="0 0 0 20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="ДОБАВЛЕНИЕ ЗАПИСИ" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1" 
                        x:Name="CloseButton"
                        Content="✕"
                        Background="Transparent"
                        BorderBrush="#CE7802"
                        BorderThickness="1"
                        Foreground="#CE7802"
                        Width="30"
                        Height="30"
                        FontSize="16"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="CloseButton_Click"/>
            </Grid>

            <!-- Форма -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Клиент -->
                    <TextBlock Text="Клиент *" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <ComboBox x:Name="ClientComboBox"
                              Style="{StaticResource ContrastComboBoxStyle}"
                              DisplayMemberPath="FullName"
                              SelectedValuePath="Id"/>

                    <!-- Мастер -->
                    <TextBlock Text="Мастер *" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <ComboBox x:Name="EmployeeComboBox"
                              Style="{StaticResource ContrastComboBoxStyle}"
                              DisplayMemberPath="FullName"
                              SelectedValuePath="Id"/>

                    <!-- Услуга -->
                    <TextBlock Text="Услуга *" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <ComboBox x:Name="ServiceComboBox"
                              Style="{StaticResource ContrastComboBoxStyle}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              SelectionChanged="ServiceComboBox_SelectionChanged"/>

                    <!-- Стоимость -->
                    <TextBlock Text="Стоимость" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <TextBox x:Name="PriceTextBox"
                             Style="{StaticResource ContrastTextBoxStyle}"
                             IsReadOnly="True"/>

                    <!-- Дата -->
                    <TextBlock Text="Дата *" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <DatePicker x:Name="AppointmentDatePicker"
                                Style="{StaticResource ContrastDatePickerStyle}"/>

                    <!-- Время -->
                    <TextBlock Text="Время *" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <TextBox x:Name="TimeTextBox"
                             Style="{StaticResource ContrastTextBoxStyle}"
                             Text="10:00"/>

                    <!-- Статус -->
                    <TextBlock Text="Статус *" 
                               Foreground="#CCCCCC" 
                               Margin="5 0 5 5" 
                               FontSize="14"/>
                    <ComboBox x:Name="StatusComboBox"
                              Style="{StaticResource ContrastComboBoxStyle}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Кнопки -->
            <Grid Grid.Row="2" Margin="0 20 0 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" 
                        x:Name="CancelButton"
                        Content="Отмена"
                        Height="45"
                        Background="Transparent"
                        BorderBrush="#FF333333"
                        BorderThickness="2"
                        Foreground="#CCCCCC"
                        FontSize="16"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Margin="0 0 5 0"
                        Click="CancelButton_Click"/>

                <Button Grid.Column="1" 
                        x:Name="SaveButton"
                        Content="Сохранить"
                        Height="45"
                        Background="#CE7802"
                        BorderThickness="0"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Margin="5 0 0 0"
                        Click="SaveButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>