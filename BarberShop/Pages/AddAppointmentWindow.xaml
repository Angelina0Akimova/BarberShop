<Window x:Class="BarberShop.Pages.AddAppointmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление записи"
        Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#FF090909"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style x:Key="CustomComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="BorderBrush" Value="#CE7802"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10 5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="CustomDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="BorderBrush" Value="#CE7802"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="CustomTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="BorderBrush" Value="#CE7802"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10 5"/>
            <Setter Property="Cursor" Value="IBeam"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="5 0 5 8"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="15" Background="#FF141414" BorderBrush="#CE7802" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0 0 0 20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="ДОБАВЛЕНИЕ ЗАПИСИ" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1" 
                        x:Name="CloseButton"
                        Content="✕"
                        Background="Transparent"
                        BorderBrush="#CE7802"
                        BorderThickness="1"
                        Foreground="#CE7802"
                        Width="30"
                        Height="30"
                        FontSize="16"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="CloseButton_Click"/>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Клиент *" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="ClientComboBox"
                              Style="{StaticResource CustomComboBoxStyle}"
                              DisplayMemberPath="FullName" Foreground="Black"/>

                    <TextBlock Text="Мастер *" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="EmployeeComboBox"
                              Style="{StaticResource CustomComboBoxStyle}"
                              DisplayMemberPath="FullName" Foreground="Black"/>

                    <TextBlock Text="Услуга *" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="ServiceComboBox"
                              Style="{StaticResource CustomComboBoxStyle}"
                              DisplayMemberPath="ServiceName"
                              SelectionChanged="ServiceComboBox_SelectionChanged" Foreground="Black"/>

                    <TextBlock Text="Стоимость" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="PriceTextBox"
                             Style="{StaticResource CustomTextBoxStyle}"
                             IsReadOnly="True" Foreground="Black"/>

                    <TextBlock Text="Дата *" Style="{StaticResource LabelStyle}"/>
                    <DatePicker x:Name="AppointmentDatePicker"
                                Style="{StaticResource CustomDatePickerStyle}" Foreground="Black"/>

                    <TextBlock Text="Время *" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TimeTextBox"
                             Style="{StaticResource CustomTextBoxStyle}"
                             Text="10:00" />

                    <TextBlock Text="Статус *" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="StatusComboBox"
                              Style="{StaticResource CustomComboBoxStyle}"
                              DisplayMemberPath="StatusName" Foreground="Black"/>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0 20 0 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" 
                        x:Name="CancelButton"
                        Content="Отмена"
                        Height="45"
                        Background="Transparent"
                        BorderBrush="#FF333333"
                        BorderThickness="2"
                        Foreground="#CCCCCC"
                        FontSize="16"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Margin="0 0 5 0"
                        Click="CancelButton_Click"/>

                <Button Grid.Column="1" 
                        x:Name="SaveButton"
                        Content="Сохранить"
                        Height="45"
                        Background="#CE7802"
                        BorderThickness="0"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Margin="5 0 0 0"
                        Click="SaveButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>