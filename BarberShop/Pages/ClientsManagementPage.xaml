<Page x:Class="BarberShop.Pages.ClientsManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="1080" d:DesignWidth="1920"
      Title="ClientsManagementPage"
      Background="#FF090909"
      Loaded="Page_Loaded">

    <Page.Resources>
        <!-- Стиль для кнопок действий -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#CE7802"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="15 0"/>
        </Style>

        <!-- Стиль для кнопки сортировки -->
        <Style x:Key="SortButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="10 0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF2A2A2A"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#CE7802"/>
                                <Setter Property="Foreground" Value="#CE7802"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для карточки клиента -->
        <Style x:Key="ClientCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF090909" Offset="0"/>
                <GradientStop Color="#FF1A1A1A" Offset="0.5"/>
                <GradientStop Color="#FF090909" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Верхняя панель с логотипом, заголовком и кнопкой выхода -->
                <Grid Grid.Row="0" Margin="0 0 0 30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Логотип слева -->
                    <Image Grid.Column="0" 
                           Source="/Iamges/logo.png" 
                           Height="60" 
                           Width="60"
                           Margin="0 0 20 0"/>

                    <!-- Заголовок по центру -->
                    <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="УПРАВЛЕНИЕ КЛИЕНТАМИ" 
                                  FontSize="28"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  TextWrapping="Wrap"/>
                        <TextBlock x:Name="AdminInfoText"
                                  Text="Администратор: Загрузка..."
                                  Foreground="#CE7802"
                                  FontSize="14"
                                  HorizontalAlignment="Center"
                                  Margin="0 5 0 0"
                                  TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Кнопка выхода справа -->
                    <Button Grid.Column="2" 
                            x:Name="BackButton"
                            Content="← Назад"
                            Background="Transparent"
                            BorderBrush="#CE7802"
                            BorderThickness="2"
                            Foreground="#CE7802"
                            FontSize="16"
                            FontWeight="Bold"
                            Padding="20 10"
                            Cursor="Hand"
                            Click="BackButton_Click"/>
                </Grid>

                <!-- Панель поиска и сортировки -->
                <Border Grid.Row="1" 
                        Background="#FF141414" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="0 0 0 30">
                    <WrapPanel Orientation="Horizontal">
                        <!-- Поиск -->
                        <Border Background="#FF1E1E1E" 
                                CornerRadius="5" 
                                Width="300"
                                Height="40"
                                Margin="0 0 20 10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" 
                                           Text="🔍" 
                                           FontSize="16" 
                                           Foreground="#666666"
                                           Margin="10 0 5 0"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" 
                                         x:Name="SearchTextBox"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="White"
                                         FontSize="14"
                                         VerticalAlignment="Center"
                                         TextChanged="SearchTextBox_TextChanged"
                                         ToolTip="Введите имя или фамилию клиента"/>
                            </Grid>
                        </Border>

                        <!-- Кнопки сортировки -->
                        <WrapPanel Orientation="Horizontal" Margin="0 0 20 10">
                            <TextBlock Text="Сортировать по дате:" 
                                       Foreground="#999999" 
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Margin="0 0 10 0"/>
                            <Button x:Name="SortDescButton"
                                    Style="{StaticResource SortButtonStyle}"
                                    Click="SortDescButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⬇️" Margin="0 0 5 0"/>
                                    <TextBlock Text="Сначала новые"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="SortAscButton"
                                    Style="{StaticResource SortButtonStyle}"
                                    Click="SortAscButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⬆️" Margin="0 0 5 0"/>
                                    <TextBlock Text="Сначала старые"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>

                        <!-- Кнопка добавления клиента -->
                        <Button x:Name="AddClientButton"
                                Style="{StaticResource ActionButtonStyle}"
                                Width="180"
                                Click="AddClientButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="➕" FontSize="16" Margin="0 0 10 0"/>
                                <TextBlock Text="Добавить клиента"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </Border>

                <!-- Список клиентов -->
                <ItemsControl Grid.Row="2" x:Name="ClientsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ClientCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Основная информация о клиенте -->
                                    <StackPanel Grid.Row="0" Margin="0 0 0 15">
                                        <TextBlock Text="{Binding FullName}"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                                   Margin="0 0 0 10"
                                                   TextWrapping="Wrap"/>

                                        <WrapPanel Margin="0 0 0 10">
                                            <TextBlock Text="📞 Телефон:" 
                                                       Foreground="#999999" 
                                                       FontSize="14"
                                                       Margin="0 0 10 0"/>
                                            <TextBlock Text="{Binding Phone}" 
                                                       Foreground="White" 
                                                       FontSize="14"
                                                       Margin="0 0 20 0"/>
                                        </WrapPanel>

                                        <WrapPanel Margin="0 0 0 10">
                                            <TextBlock Text="✉️ Email:" 
                                                       Foreground="#999999" 
                                                       FontSize="14"
                                                       Margin="0 0 10 0"/>
                                            <TextBlock Text="{Binding Email}" 
                                                       Foreground="White" 
                                                       FontSize="14"
                                                       TextWrapping="Wrap"/>
                                        </WrapPanel>

                                        <!-- Логин (ID) и дата регистрации -->
                                        <WrapPanel>
                                            <Border Background="#FF2A2A2A"
                                                    CornerRadius="5"
                                                    Padding="10 5"
                                                    Margin="0 0 10 5">
                                                <TextBlock>
                                                    <Run Text="Email:" Foreground="#999999"/>
                                                    <Run Text="{Binding Login}" Foreground="#CE7802" FontWeight="Bold"/>
                                                </TextBlock>
                                            </Border>

                                            <Border Background="#FF2A2A2A"
                                                    CornerRadius="5"
                                                    Padding="10 5"
                                                    Margin="0 0 10 5">
                                                <TextBlock>
                                                    <Run Text="📅 Регистрация:" Foreground="#999999"/>
                                                    <Run Text="{Binding RegistrationDate}" Foreground="White"/>
                                                </TextBlock>
                                            </Border>

                                            <Border Background="#FF2A2A2A"
                                                    CornerRadius="5"
                                                    Padding="10 5"
                                                    Margin="0 0 10 5">
                                                <TextBlock>
                                                    <Run Text="🕒 Последний визит:" Foreground="#999999"/>
                                                    <Run Text="{Binding LastVisitDate}" Foreground="White"/>
                                                </TextBlock>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>

                                    <!-- Кнопка изменения пароля -->
                                    <Button Grid.Row="1"
                                            x:Name="ChangePasswordButton"
                                            Width="150"
                                            Height="40"
                                            Background="Transparent"
                                            BorderBrush="#CE7802"
                                            BorderThickness="2"
                                            Foreground="#CE7802"
                                            FontSize="13"
                                            FontWeight="Bold"
                                            Cursor="Hand"
                                            HorizontalAlignment="Left"
                                            Margin="0 0 0 15"
                                            Tag="{Binding UserId}"
                                            Click="ChangePasswordButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🔑" FontSize="14" Margin="0 0 5 0"/>
                                            <TextBlock Text="Изменить пароль"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Статус активности -->
                                    <Border Grid.Row="2"
                                            Background="{Binding StatusColor}"
                                            CornerRadius="5"
                                            Padding="10 5"
                                            Margin="0 10 0 0"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="White"
                                                   FontSize="12"
                                                   FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Сообщение, если клиенты не найдены -->
                <TextBlock Grid.Row="3" x:Name="NoClientsText"
                           Text="Клиенты не найдены"
                           Foreground="#666666"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           Margin="0 50"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>

                <!-- Нижний колонтитул -->
                <Border Grid.Row="4" 
                        Background="#FF1E1E1E" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="0 30 0 0">
                    <TextBlock Text="© 2026 BARBERSHOP «ПОДДУБНЫЙ». Все права защищены." 
                               Foreground="#666666" 
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>