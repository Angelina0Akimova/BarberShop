<Page x:Class="BarberShop.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="1080" d:DesignWidth="1920"
      Title="AdminPage"
      Background="#FF090909"
      Loaded="Page_Loaded">

    <Page.Resources>
        <!-- Стиль для кнопок боковой панели -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0 2 0 2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="20 0">
                            <ContentPresenter HorizontalAlignment="Left" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF2A2A2A"/>
                                <Setter Property="Foreground" Value="#CE7802"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для карточек информации -->
        <Style x:Key="InfoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="25"/>
            <Setter Property="Margin" Value="0 0 0 20"/>
        </Style>

        <!-- Стиль для кнопок действий -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="#CE7802"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <!-- Стиль для полей информации -->
        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
        </Style>

        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Фоновый градиент -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF090909" Offset="0"/>
                <GradientStop Color="#FF1A1A1A" Offset="0.5"/>
                <GradientStop Color="#FF090909" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая боковая панель с навигацией -->
        <Border Grid.Column="0" 
                Background="#FF141414" 
                CornerRadius="0 20 20 0"
                Margin="0 0 0 0">
            <StackPanel Margin="20 30 20 30">
                <!-- Логотип -->
                <Image Source="/Iamges/logo.png" 
                       Height="80" 
                       Width="80"
                       Margin="0 0 0 30"
                       HorizontalAlignment="Left"/>

                <!-- Заголовок навигации -->
                <TextBlock Text="НАВИГАЦИЯ" 
                          Foreground="#666666" 
                          FontSize="12" 
                          Margin="0 0 0 15"/>

                <!-- Кнопки навигации -->
                <Button Style="{StaticResource SidebarButtonStyle}" 
                        x:Name="AppointmentsButton"
                        Click="NavigationButton_Click"
                        Tag="Appointments">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📅" FontSize="18" Margin="0 0 15 0"/>
                        <TextBlock Text="Записи"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource SidebarButtonStyle}" 
                        x:Name="ClientsButton"
                        Click="NavigationButton_Click"
                        Tag="Clients">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👥" FontSize="18" Margin="0 0 15 0"/>
                        <TextBlock Text="Клиенты"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource SidebarButtonStyle}" 
                        x:Name="MastersButton"
                        Click="NavigationButton_Click"
                        Tag="Masters">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💇‍♂️" FontSize="18" Margin="0 0 15 0"/>
                        <TextBlock Text="Мастера"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource SidebarButtonStyle}" 
                        x:Name="ReportsButton"
                        Click="NavigationButton_Click"
                        Tag="Reports">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊" FontSize="18" Margin="0 0 15 0"/>
                        <TextBlock Text="Отчеты"/>
                    </StackPanel>
                </Button>

                <!-- Разделитель -->
                <Border Height="1" Background="#333333" Margin="0 30"/>

                <!-- Краткая информация в боковой панели -->
                <TextBlock Text="ИНФОРМАЦИЯ" 
                          Foreground="#666666" 
                          FontSize="12" 
                          Margin="0 0 0 15"/>

                <TextBlock Text="Текущий администратор:" 
                          Foreground="#999999" 
                          FontSize="14"/>
                <TextBlock x:Name="SidebarAdminName" 
                          Text="Загрузка..." 
                          Foreground="White" 
                          FontSize="16" 
                          FontWeight="Bold" 
                          Margin="0 0 0 15"/>

                <TextBlock Text="Всего клиентов:" 
                          Foreground="#999999" 
                          FontSize="14"/>
                <TextBlock x:Name="TotalClientsText" 
                          Text="0" 
                          Foreground="#CE7802" 
                          FontSize="24" 
                          FontWeight="Bold" 
                          Margin="0 0 0 15"/>

                <TextBlock Text="Записей сегодня:" 
                          Foreground="#999999" 
                          FontSize="14"/>
                <TextBlock x:Name="TodayAppointmentsText" 
                          Text="0" 
                          Foreground="#CE7802" 
                          FontSize="24" 
                          FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Основная область контента -->
        <ScrollViewer Grid.Column="1" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="30">

                <!-- Верхняя панель с ролью и кнопкой выхода -->
                <Grid Margin="0 0 0 30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Бейдж с ролью и имя -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Background="#CE7802" 
                                CornerRadius="5" 
                                Padding="15 5"
                                Margin="0 0 15 0">
                            <TextBlock Text="АДМИНИСТРАТОР" 
                                      Foreground="White" 
                                      FontWeight="Bold"
                                      FontSize="14"/>
                        </Border>
                        <TextBlock x:Name="AdminNameText" 
                                  Text="Загрузка..."
                                  Foreground="White"
                                  FontSize="20"
                                  FontWeight="Bold"
                                  VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Пустой столбец для выравнивания -->
                    <TextBlock Grid.Column="1"/>

                    <!-- Кнопка выхода -->
                    <Button Grid.Column="2" 
                            x:Name="LogoutButton"
                            Content="🚪 Выйти"
                            Background="Transparent"
                            BorderBrush="#CE7802"
                            BorderThickness="2"
                            Foreground="#CE7802"
                            FontSize="16"
                            FontWeight="Bold"
                            Padding="20 10"
                            Cursor="Hand"
                            Click="LogoutButton_Click"/>
                </Grid>

                <!-- Заголовок страницы -->
                <TextBlock Text="ЛИЧНЫЙ КАБИНЕТ АДМИНИСТРАТОРА" 
                          FontSize="28"
                          FontWeight="Bold"
                          Foreground="White"
                          Margin="0 0 0 30"/>

                <!-- Карточка с данными администратора -->
                <Border Style="{StaticResource InfoCardStyle}">
                    <StackPanel>
                        <!-- Заголовок карточки -->
                        <TextBlock Text="МОИ ДАННЫЕ" 
                                  Foreground="#CE7802" 
                                  FontSize="18" 
                                  FontWeight="Bold" 
                                  Margin="0 0 0 20"/>

                        <!-- Сетка с данными -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="300"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Левая колонка: Имя -->
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                      Text="Имя:" 
                                      Style="{StaticResource InfoLabelStyle}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" 
                                      x:Name="FirstNameText" 
                                      Text="-" 
                                      Style="{StaticResource InfoValueStyle}"/>

                            <!-- Левая колонка: Фамилия -->
                            <TextBlock Grid.Row="1" Grid.Column="0" 
                                      Text="Фамилия:" 
                                      Style="{StaticResource InfoLabelStyle}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" 
                                      x:Name="LastNameText" 
                                      Text="-" 
                                      Style="{StaticResource InfoValueStyle}"/>

                            <!-- Левая колонка: Телефон -->
                            <TextBlock Grid.Row="2" Grid.Column="0" 
                                      Text="Телефон:" 
                                      Style="{StaticResource InfoLabelStyle}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" 
                                      x:Name="PhoneText" 
                                      Text="-" 
                                      Style="{StaticResource InfoValueStyle}"/>

                            <!-- Левая колонка: Логин (Email) -->
                            <TextBlock Grid.Row="3" Grid.Column="0" 
                                      Text="Логин:" 
                                      Style="{StaticResource InfoLabelStyle}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" 
                                      x:Name="LoginText" 
                                      Text="-" 
                                      Style="{StaticResource InfoValueStyle}"/>

                            <!-- Левая колонка: Пароль (скрыт) -->
                            <TextBlock Grid.Row="4" Grid.Column="0" 
                                      Text="Пароль:" 
                                      Style="{StaticResource InfoLabelStyle}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" 
                                      x:Name="PasswordText" 
                                      Text="••••••••" 
                                      Style="{StaticResource InfoValueStyle}"/>

                            <!-- Правая колонка: Дата регистрации -->
                            <TextBlock Grid.Row="0" Grid.Column="2" 
                                      Text="Дата регистрации:" 
                                      Style="{StaticResource InfoLabelStyle}"
                                      Margin="50 0 0 15"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" 
                                      x:Name="RegistrationDateText" 
                                      Text="-" 
                                      Style="{StaticResource InfoValueStyle}"
                                      Margin="200 0 0 15"/>

                            <!-- Правая колонка: Статус -->
                            <TextBlock Grid.Row="1" Grid.Column="2" 
                                      Text="Статус:" 
                                      Style="{StaticResource InfoLabelStyle}"
                                      Margin="50 0 0 15"/>
                            <Border Grid.Row="1" Grid.Column="2" 
                                    Background="#4CAF50"
                                    CornerRadius="5"
                                    Padding="15 5"
                                    Margin="200 0 0 15"
                                    HorizontalAlignment="Left">
                                <TextBlock x:Name="StatusText" 
                                          Text="Активен" 
                                          Foreground="White" 
                                          FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Кнопки действий -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 20">
                    <Button x:Name="EditDataButton" 
                            Style="{StaticResource ActionButtonStyle}"
                            Width="200"
                            Click="EditDataButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✏️" FontSize="18" Margin="0 0 10 0"/>
                            <TextBlock Text="Изменить данные"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="ChangePasswordButton" 
                            Style="{StaticResource ActionButtonStyle}"
                            Width="200"
                            Background="Transparent"
                            BorderBrush="#CE7802"
                            BorderThickness="2"
                            Click="ChangePasswordButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔒" FontSize="18" Margin="0 0 10 0"/>
                            <TextBlock Text="Изменить пароль"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Нижний колонтитул -->
                <Border Background="#FF1E1E1E" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="0 30 0 0">
                    <TextBlock Text="© 2026 BARBERSHOP «ПОДДУБНЫЙ». Все права защищены." 
                               Foreground="#666666" 
                               HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>