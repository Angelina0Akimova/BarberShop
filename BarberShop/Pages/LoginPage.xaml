<Page x:Class="BarberShop.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage"
      Background="#FF090909">

    <Grid>
        <!-- Основной контейнер с вертикальным выравниванием -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">

            <!-- Логотип (белый) - вставь своё изображение в папку Images с именем logo.png -->
            <Image Source="/Iamges/logo.png" Height="200" Width="200" Margin="0 0 0 30" 
                   HorizontalAlignment="Center"/>

            <!-- Заголовок -->
            <TextBlock Text="Добро пожаловать!" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="White" 
                       HorizontalAlignment="Center" 
                       Margin="0 0 0 30"/>

            <!-- Поле для логина (телефон или email) -->
            <TextBlock Text="Телефон или Email" 
                       Foreground="#CCCCCC" 
                       Margin="5 0 5 5" 
                       FontSize="14"/>
            <TextBox x:Name="LoginTextBox" 
                     Height="45" 
                     Background="#FF1E1E1E" 
                     BorderBrush="#FF333333" 
                     BorderThickness="1" 
                     Foreground="White" 
                     FontSize="16" 
                     Padding="10 5" 
                     Margin="0 0 0 20"/>

            <!-- Поле для пароля -->
            <TextBlock Text="Пароль" 
                       Foreground="#CCCCCC" 
                       Margin="5 0 5 5" 
                       FontSize="14"/>
            <PasswordBox x:Name="PasswordBox" 
                         Height="45" 
                         Background="#FF1E1E1E" 
                         BorderBrush="#FF333333" 
                         BorderThickness="1" 
                         Foreground="White" 
                         FontSize="16" 
                         Padding="10 5" 
                         Margin="0 0 0 25"/>

            <!-- Кнопка входа -->
            <Button x:Name="LoginButton" 
                    Content="ВОЙТИ" 
                    Height="50" 
                    Background="#CE7802" 
                    BorderThickness="0" 
                    Foreground="White" 
                    FontSize="18" 
                    FontWeight="Bold" 
                    Cursor="Hand"
                    Click="LoginButton_Click"/>

            <!-- Текст "Забыли пароль" -->
            <TextBlock x:Name="ForgotPasswordText" 
                       Text="Забыли пароль?" 
                       Foreground="#CE7802" 
                       HorizontalAlignment="Center" 
                       Margin="0 20 0 0" 
                       Cursor="Hand"
                       TextDecorations="Underline"
                       MouseLeftButtonDown="ForgotPasswordText_MouseLeftButtonDown"/>

            <!-- Всплывающая подсказка (изначально скрыта) -->
            <Border x:Name="ToolTipBorder" 
                    Background="#FF1E1E1E" 
                    BorderBrush="#CE7802" 
                    BorderThickness="1" 
                    CornerRadius="5" 
                    Margin="0 10 0 0" 
                    Padding="15 10" 
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ℹ️" 
                               FontSize="20" 
                               Foreground="#CE7802" 
                               Margin="0 0 10 0"/>
                    <TextBlock Text="Для восстановления пароля, обратитесь к администратору" 
                               Foreground="White" 
                               FontSize="14" 
                               TextWrapping="Wrap" 
                               Width="250"/>
                </StackPanel>
            </Border>

            <!-- Разделитель -->
            <StackPanel Orientation="Horizontal" Margin="0 20 0 20">
                <Border Height="1" Background="#333333" Width="130" VerticalAlignment="Center"/>
                <TextBlock Text="или" Foreground="#666666" Margin="10 0" FontSize="14"/>
                <Border Height="1" Background="#333333" Width="130" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Кнопка "Войти как гость" -->
            <Button x:Name="GuestButton" 
                    Content="👤 ВОЙТИ КАК ГОСТЬ" 
                    Height="45" 
                    Background="Transparent" 
                    BorderBrush="#CE7802" 
                    BorderThickness="2" 
                    Foreground="#CE7802" 
                    FontSize="16" 
                    FontWeight="SemiBold" 
                    Cursor="Hand"
                    Click="GuestButton_Click"/>

            <!-- Сообщение об ошибке -->
            <TextBlock x:Name="ErrorMessageText" 
                       Foreground="#FF4444" 
                       HorizontalAlignment="Center" 
                       Margin="0 10 0 0" 
                       TextWrapping="Wrap" 
                       Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Page>