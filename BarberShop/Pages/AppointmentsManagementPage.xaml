<Page x:Class="BarberShop.Pages.AppointmentsManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="1080" d:DesignWidth="1920"
      Title="AppointmentsManagementPage"
      Background="#FF090909"
      Loaded="Page_Loaded">

    <Page.Resources>
        <!-- Стиль для кнопок действий -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#CE7802"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="15 0"/>
        </Style>

        <!-- Стиль для карточки записи -->
        <Style x:Key="AppointmentCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
        </Style>

        <!-- Стиль для заголовков секций -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0 20 0 15"/>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Фоновый градиент -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF090909" Offset="0"/>
                <GradientStop Color="#FF1A1A1A" Offset="0.5"/>
                <GradientStop Color="#FF090909" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">

                <!-- Верхняя панель с логотипом, заголовком и кнопкой назад -->
                <Grid Margin="0 0 0 30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Логотип слева -->
                    <Image Grid.Column="0" 
                           Source="/Iamges/logo.png" 
                           Height="60" 
                           Width="60"
                           Margin="0 0 20 0"/>

                    <!-- Заголовок по центру -->
                    <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="УПРАВЛЕНИЕ ЗАПИСЯМИ" 
                                  FontSize="28"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"/>
                        <TextBlock x:Name="AdminInfoText"
                                  Text="Администратор: Загрузка..."
                                  Foreground="#CE7802"
                                  FontSize="14"
                                  HorizontalAlignment="Center"
                                  Margin="0 5 0 0"/>
                    </StackPanel>

                    <!-- Кнопка назад -->
                    <Button Grid.Column="2" 
                            x:Name="BackButton"
                            Content="← Назад"
                            Background="Transparent"
                            BorderBrush="#CE7802"
                            BorderThickness="2"
                            Foreground="#CE7802"
                            FontSize="16"
                            FontWeight="Bold"
                            Padding="20 10"
                            Cursor="Hand"
                            Click="BackButton_Click"/>
                </Grid>

                <!-- Панель с кнопкой добавления -->
                <Border Background="#FF141414" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="0 0 0 30"
                        HorizontalAlignment="Right">
                    <Button x:Name="AddAppointmentButton"
                            Style="{StaticResource ActionButtonStyle}"
                            Width="200"
                            Click="AddAppointmentButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="➕" FontSize="16" Margin="0 0 10 0"/>
                            <TextBlock Text="Добавить запись"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Секция: Сегодняшние записи -->
                <TextBlock Text="📅 ЗАПИСИ НА СЕГОДНЯ" 
                          Style="{StaticResource SectionTitleStyle}"/>

                <ItemsControl x:Name="TodayAppointmentsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource AppointmentCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Информация о записи -->
                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <!-- Клиент и телефон -->
                                        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                                            <TextBlock Text="👤 " Foreground="#CE7802" FontSize="16"/>
                                            <TextBlock Text="{Binding ClientName}" 
                                                      FontSize="18" 
                                                      FontWeight="Bold" 
                                                      Foreground="White"
                                                      Margin="0 0 10 0"/>
                                            <TextBlock Text="📞 " Foreground="#CE7802" FontSize="16"/>
                                            <TextBlock Text="{Binding ClientPhone}" 
                                                      Foreground="#CCCCCC" 
                                                      FontSize="16"/>
                                        </StackPanel>

                                        <!-- Детали записи -->
                                        <WrapPanel Margin="0 0 0 10">
                                            <Border Background="#FF2A2A2A"
                                                    CornerRadius="5"
                                                    Padding="10 5"
                                                    Margin="0 0 10 5">
                                                <TextBlock>
                                                    <Run Text="💈 " Foreground="#CE7802"/>
                                                    <Run Text="{Binding ServiceName}" Foreground="White"/>
                                                </TextBlock>
                                            </Border>

                                            <Border Background="#FF2A2A2A"
                                                    CornerRadius="5"
                                                    Padding="10 5"
                                                    Margin="0 0 10 5">
                                                <TextBlock>
                                                    <Run Text="👨‍💼 " Foreground="#CE7802"/>
                                                    <Run Text="{Binding EmployeeName}" Foreground="White"/>
                                                </TextBlock>
                                            </Border>

                                            <Border Background="#FF2A2A2A"
                                                    CornerRadius="5"
                                                    Padding="10 5"
                                                    Margin="0 0 10 5">
                                                <TextBlock>
                                                    <Run Text="⏰ " Foreground="#CE7802"/>
                                                    <Run Text="{Binding Time}" Foreground="White"/>
                                                </TextBlock>
                                            </Border>

                                            <Border Background="#4CAF50"
                                                    CornerRadius="5"
                                                    Padding="10 5"
                                                    Margin="0 0 10 5">
                                                <TextBlock Text="{Binding Price}" 
                                                           Foreground="White" 
                                                           FontWeight="Bold"/>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>

                                    <!-- Кнопки действий -->
                                    <!-- Кнопки действий -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" 
            Orientation="Horizontal"
            VerticalAlignment="Top">
                                        <Button x:Name="EditButton"
            Width="40"
            Height="40"
            Background="Transparent"
            BorderBrush="#CE7802"
            BorderThickness="2"
            Foreground="#CE7802"
            FontSize="16"
            Cursor="Hand"
            Margin="0 0 5 0"
            Tag="{Binding AppointmentID}"
            Click="EditButton_Click">
                                            <TextBlock Text="✏️" FontFamily="Segoe UI Emoji"/>
                                        </Button>
                                        <Button x:Name="DeleteButton"
            Width="40"
            Height="40"
            Background="Transparent"
            BorderBrush="#FF4444"
            BorderThickness="2"
            Foreground="#FF4444"
            FontSize="16"
            Cursor="Hand"
            Tag="{Binding AppointmentID}"
            Click="DeleteButton_Click">
                                            <TextBlock Text="🗑️" FontFamily="Segoe UI Emoji"/>
                                        </Button>
                                    </StackPanel>

                                    <!-- Статус (внизу) -->
                                    <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                            Background="{Binding StatusColor}"
                                            CornerRadius="5"
                                            Padding="10 5"
                                            Margin="0 10 0 0"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="White"
                                                   FontSize="12"
                                                   FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Сообщение, если нет сегодняшних записей -->
                <TextBlock x:Name="NoTodayAppointmentsText"
                           Text="Нет записей на сегодня"
                           Foreground="#666666"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Margin="0 20"
                           Visibility="Collapsed"/>

                <!-- Секция: Предстоящие записи -->
                <TextBlock Text="📅 ПРЕДСТОЯЩИЕ ЗАПИСИ" 
                          Style="{StaticResource SectionTitleStyle}"/>

                <ItemsControl x:Name="UpcomingAppointmentsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource AppointmentCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Информация о записи -->
                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <!-- Клиент и телефон -->
                                        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                                            <TextBlock Text="👤 " Foreground="#CE7802" FontSize="16"/>
                                            <TextBlock Text="{Binding ClientName}" 
                                                      FontSize="18" 
                                                      FontWeight="Bold" 
                                                      Foreground="White"
                                                      Margin="0 0 10 0"/>
                                            <TextBlock Text="📞 " Foreground="#CE7802" FontSize="16"/>
                                            <TextBlock Text="{Binding ClientPhone}" 
                                                      Foreground="#CCCCCC" 
                                                      FontSize="16"/>
                                        </StackPanel>

                                        <!-- Дата и детали -->
                                        <TextBlock Text="{Binding Date}" 
                                                   Foreground="#CE7802" 
                                                   FontSize="14"
                                                   Margin="0 0 0 5"/>

                                        <WrapPanel Margin="0 0 0 10">
                                            <Border Background="#FF2A2A2A"
                                                    CornerRadius="5"
                                                    Padding="10 5"
                                                    Margin="0 0 10 5">
                                                <TextBlock>
                                                    <Run Text="💈 " Foreground="#CE7802"/>
                                                    <Run Text="{Binding ServiceName}" Foreground="White"/>
                                                </TextBlock>
                                            </Border>

                                            <Border Background="#FF2A2A2A"
                                                    CornerRadius="5"
                                                    Padding="10 5"
                                                    Margin="0 0 10 5">
                                                <TextBlock>
                                                    <Run Text="👨‍💼 " Foreground="#CE7802"/>
                                                    <Run Text="{Binding EmployeeName}" Foreground="White"/>
                                                </TextBlock>
                                            </Border>

                                            <Border Background="#4CAF50"
                                                    CornerRadius="5"
                                                    Padding="10 5"
                                                    Margin="0 0 10 5">
                                                <TextBlock Text="{Binding Price}" 
                                                           Foreground="White" 
                                                           FontWeight="Bold"/>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>

                                    <!-- Кнопки действий -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" 
                                                Orientation="Horizontal"
                                                VerticalAlignment="Top">
                                        <Button Width="40"
                                                Height="40"
                                                Background="Transparent"
                                                BorderBrush="#CE7802"
                                                BorderThickness="2"
                                                Foreground="#CE7802"
                                                FontSize="16"
                                                Cursor="Hand"
                                                Margin="0 0 5 0"
                                                Tag="{Binding AppointmentId}"
                                                Click="EditButton_Click">
                                            <TextBlock Text="✏️"/>
                                        </Button>
                                        <Button Width="40"
                                                Height="40"
                                                Background="Transparent"
                                                BorderBrush="#FF4444"
                                                BorderThickness="2"
                                                Foreground="#FF4444"
                                                FontSize="16"
                                                Cursor="Hand"
                                                Tag="{Binding AppointmentId}"
                                                Click="DeleteButton_Click">
                                            <TextBlock Text="🗑️"/>
                                        </Button>
                                    </StackPanel>

                                    <!-- Статус (внизу) -->
                                    <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                            Background="{Binding StatusColor}"
                                            CornerRadius="5"
                                            Padding="10 5"
                                            Margin="0 10 0 0"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="White"
                                                   FontSize="12"
                                                   FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Сообщение, если нет предстоящих записей -->
                <TextBlock x:Name="NoUpcomingAppointmentsText"
                           Text="Нет предстоящих записей"
                           Foreground="#666666"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Margin="0 20"
                           Visibility="Collapsed"/>

                <!-- Секция: Прошедшие записи -->
                <TextBlock Text="📅 ПРОШЕДШИЕ ЗАПИСИ" 
                          Style="{StaticResource SectionTitleStyle}"/>

                <ItemsControl x:Name="PastAppointmentsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource AppointmentCardStyle}" Opacity="0.7">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Информация о записи -->
                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <!-- Клиент и телефон -->
                                        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                                            <TextBlock Text="👤 " Foreground="#CE7802" FontSize="16"/>
                                            <TextBlock Text="{Binding ClientName}" 
                                                      FontSize="18" 
                                                      FontWeight="Bold" 
                                                      Foreground="White"
                                                      Margin="0 0 10 0"/>
                                        </StackPanel>

                                        <!-- Дата и детали -->
                                        <TextBlock Text="{Binding Date}" 
                                                   Foreground="#999999" 
                                                   FontSize="14"
                                                   Margin="0 0 0 5"/>

                                        <WrapPanel Margin="0 0 0 10">
                                            <Border Background="#FF2A2A2A"
                                                    CornerRadius="5"
                                                    Padding="10 5"
                                                    Margin="0 0 10 5">
                                                <TextBlock Text="{Binding ServiceName}" Foreground="#CCCCCC"/>
                                            </Border>
                                            <Border Background="#FF2A2A2A"
                                                    CornerRadius="5"
                                                    Padding="10 5"
                                                    Margin="0 0 10 5">
                                                <TextBlock Text="{Binding EmployeeName}" Foreground="#CCCCCC"/>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>

                                    <!-- Статус (внизу) -->
                                    <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                            Background="#666666"
                                            CornerRadius="5"
                                            Padding="10 5"
                                            Margin="0 10 0 0"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="White"
                                                   FontSize="12"
                                                   FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Сообщение, если нет прошедших записей -->
                <TextBlock x:Name="NoPastAppointmentsText"
                           Text="Нет прошедших записей"
                           Foreground="#666666"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Margin="0 20"
                           Visibility="Collapsed"/>

                <!-- Нижний колонтитул -->
                <Border Background="#FF1E1E1E" 
                        CornerRadius="10" 
                        Padding="20" 
                        Margin="0 30 0 0">
                    <TextBlock Text="© 2026 BARBERSHOP «ПОДДУБНЫЙ». Все права защищены." 
                               Foreground="#666666" 
                               HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>